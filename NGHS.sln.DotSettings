	<s:Boolean x:Key="/Default/Environment/InjectedLayers/FileInjectedLayer/=73A555960BCA43488C93BB2A41D77A54/@KeyIndexDefined">True</s:Boolean>
	<s:String x:Key="/Default/Environment/InjectedLayers/FileInjectedLayer/=73A555960BCA43488C93BB2A41D77A54/RelativePath/@EntryValue">..\NGHS.DotSettings</s:String>
	<s:Boolean x:Key="/Default/Environment/InjectedLayers/InjectedLayerCustomization/=File73A555960BCA43488C93BB2A41D77A54/@KeyIndexDefined">True</s:Boolean>
	<s:Double x:Key="/Default/Environment/InjectedLayers/InjectedLayerCustomization/=File73A555960BCA43488C93BB2A41D77A54/RelativePriority/@EntryValue">1</s:Double>

      <?define deltashell_output_folder="$(var.SolutionDir)bin\$(var.Configuration)\"?>
    <?endif?>
    <?define deltashell_gui_bin="$(var.deltashell_output_folder)DeltaShell"?>
  <?endif?>
  <?define deltashell_plugins_files="$(var.SolutionDir)bin\$(var.Configuration)\Plugins"?>
</Include>

<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <UsingTask
    TaskName="GetFileVersion"
    TaskFactory="CodeTaskFactory"
    AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.v4.0.dll">

    <ParameterGroup>
      <AssemblyPath ParameterType="System.String" Required="true" />
      <Version ParameterType="System.String" Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.Diagnostics" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
            Version = FileVersionInfo.GetVersionInfo(AssemblyPath).FileVersion;
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="TargetSystemTests">
    <!-- Check (system test) -->
    <Message Text="Checking MSI at state : $(Status)" Importance="high"/>
    <Message Text="My product name : $(ProductName)" Importance="high"/>
    <Message Text="My application name : $(ApplicationName)" Importance="high"/>
    <Message Text="My distribution name : $(DistributionName)" Importance="high"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TargetFilesAndFoldersSystemTests" Properties="Status=$(Status);ProductName=$(ProductName);ApplicationName=$(ApplicationName);DistributionName=$(DistributionName);ConditionState=$(ConditionState);CheckingFor=$(CheckingFor)" ContinueOnError="WarnAndContinue"/>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TargetShortCutsSystemTests" Properties="Status=$(Status);ProductName=$(ProductName);ConditionState=$(ConditionState);CheckingFor=$(CheckingFor)" ContinueOnError="WarnAndContinue" />
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TargetRegistrySystemTests" Properties="ProductCode=$(ProductCode);Status=$(Status);ProductName=$(ProductName);ConditionState=$(ConditionState);CheckingFor=$(CheckingFor)" ContinueOnError="WarnAndContinue" />

  </Target>

  <Target Name="TargetFilesAndFoldersSystemTests">
    <Message Text="Checking Files and Folders" Importance="high"/>
    <Message Text="Checking Folders $(CheckingFor) with $(ConditionState)" Importance="high"/>
    <PropertyGroup>
      <_Package>Files</_Package>
      <_File>Product_wxs</_File>
    </PropertyGroup>

    <PropertyGroup>
      <_CheckDeltaShellFolder Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName)\bin</_CheckDeltaShellFolder>
      <_CheckDeltaShellFolder Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName) ($(BUILD_NUMBER))\bin</_CheckDeltaShellFolder>
    </PropertyGroup>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell bin folder;
                          KeyValue=$(_CheckDeltaShellFolder);"
             ContinueOnError="WarnAndContinue"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TargetDeltaShellFilesAndFoldersSystemTests"
             Properties=" _CheckDeltaShellFolder=$(_CheckDeltaShellFolder);"
             Condition="'$(ConditionState)' == 'false'"
             ContinueOnError="WarnAndContinue"/>

    <Message Text="If DeltaShell Folder does not exist, do not check for files and file versions in that folder." Importance="high" Condition="'$(ConditionState)' == 'true'" />

    <PropertyGroup>
      <_CheckPluginsFolder Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName)\Plugins</_CheckPluginsFolder>
      <_CheckPluginsFolder Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName) ($(BUILD_NUMBER))\Plugins</_CheckPluginsFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell Plugins folder;
                          KeyValue=$(_CheckPluginsFolder);"
             ContinueOnError="WarnAndContinue"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TargetPluginsFilesAndFoldersSystemTests"
             Properties=" _CheckPluginsFolder=$(_CheckPluginsFolder);"
             Condition="'$(ConditionState)' == 'false' AND '$(MyCultureOutputFolder)' != 'fmo\' "
             ContinueOnError="WarnAndContinue"/>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TargetPluginsFilesAndFoldersForOpenSystemTests"
             Properties=" _CheckPluginsFolder=$(_CheckPluginsFolder);"
             Condition="'$(ConditionState)' == 'false' AND '$(MyCultureOutputFolder)' == 'fmo\' "
             ContinueOnError="WarnAndContinue"/>
    <Message Text="If Plugins Folder does not exist, do not check for files and file versions in that folder." Importance="high" Condition="'$(ConditionState)' == 'true'" />

  </Target>

<Target Name="TargetPluginsFilesAndFoldersForOpenSystemTests" DependsOnTargets="TargetSetVersioningForSystemTest">
    <!--We know Plugins folder exist, check for specific files and file versions in the Plugins folder-->
    <PropertyGroup>
      <_Package>PluginFiles</_Package>
      <_File>HarvestedPluginFiles_wxs</_File>
      <_VersionsFile>FM_Properties</_VersionsFile>
    </PropertyGroup>


    <PropertyGroup>
      <_CheckKernelsFolder>$(_CheckPluginsFolder)\DeltaShell.Dimr\kernels\x64</_CheckKernelsFolder>
      <_OpenCondition Condition="Exists('$(_CheckKernelsFolder)')">true</_OpenCondition>
      <_OpenCondition Condition="!Exists('$(_CheckKernelsFolder)')">false</_OpenCondition>
    </PropertyGroup>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=Kernels folder;
                          KeyValue=$(_CheckKernelsFolder);
						  Condition=$(_OpenCondition)"
             ContinueOnError="WarnAndContinue"/>




    <!-- GridEditorPlugin DOES NOT EXISTS IN 2D3D PLUGIN (D3DFMIQ-1279)
	<PropertyGroup>
      <_CheckGridGeomStatefulFolder>$(_CheckPluginsFolder)\DeltaShell.Plugins.GridEditor\Lib</_CheckGridGeomStatefulFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=GridGeomStateful folder;
                          KeyValue=$(_CheckGridGeomStatefulFolder)"
             ContinueOnError="WarnAndContinue"/> -->

    <PropertyGroup>
      <_CheckRgfGridFolder>$(_CheckPluginsFolder)\DeltaShell.Plugins.FMSuite.Common.Gui\plugins-qt\x64\bin</_CheckRgfGridFolder>
	    <_OpenCondition Condition="Exists('$(_CheckRgfGridFolder)')">true</_OpenCondition>
      <_OpenCondition Condition="!Exists('$(_CheckRgfGridFolder)')">false</_OpenCondition>
    </PropertyGroup>


    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=RgfGrid folder;
                          KeyValue=$(_CheckRgfGridFolder);
						  Condition=$(_OpenCondition)"
             ContinueOnError="WarnAndContinue"/>

        <PropertyGroup>
      <_CheckNGHS_IOFolder>$(_CheckPluginsFolder)\DeltaShell.NGHS.IO</_CheckNGHS_IOFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell NGHS IO folder;
                          KeyValue=$(_CheckNGHS_IOFolder)"
             ContinueOnError="WarnAndContinue"/>

    <!-- GridEditorPlugin DOES NOT EXISTS IN 2D3D PLUGIN (D3DFMIQ-1279) SO FILES ARE BUILD FOR 1D2D ONLY
	<PropertyGroup>
      <_CheckNGHS_IO_NetCDFDllFile>io_netcdf.dll</_CheckNGHS_IO_NetCDFDllFile>
      <_CheckNGHS_Deltares_UgridDllFile>Deltares.UGrid.dll</_CheckNGHS_Deltares_UgridDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckNGHS_IO_NetCDFDllFile);
                          KeyValue=$(_CheckNGHS_IOFolder)\$(_CheckNGHS_IO_NetCDFDllFile);
                          FileVersion=$(_CheckNGHS_IO_NetCDFDllFileVersion)"
             ContinueOnError="WarnAndContinue"/>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckNGHS_IO_NetCDFDllFile);
                          KeyValue=$(_CheckNGHS_IOFolder)\$(_CheckNGHS_Deltares_UgridDllFile);
                          FileVersion=$(_CheckNGHS_Deltares_UgridDllFileVersion)"
             ContinueOnError="WarnAndContinue"/> -->

    <!-- ECModule REPLACEMENT DOES NOT EXISTS IN 2D3D PLUGIN (DSFRAME-930)
	<PropertyGroup>
      <_CheckMeshKernelApiFolder>$(_CheckNGHS_IOFolder)\win-x64\native</_CheckMeshKernelApiFolder>
      <_CheckMeshKernelApiExpFile>MeshKernelApi.exp</_CheckMeshKernelApiExpFile>
      <_CheckMeshKernelApiLibFile>MeshKernelApi.lib</_CheckMeshKernelApiLibFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=MeshKernelApi folder;
                          KeyValue=$(_CheckMeshKernelApiFolder)"
             ContinueOnError="WarnAndContinue"/>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=MeshKernelApi exp file;
                          KeyValue=$(_CheckMeshKernelApiFolder)\$(_CheckMeshKernelApiExpFile)"
             ContinueOnError="WarnAndContinue"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=MeshKernelApi lib file;
                          KeyValue=$(_CheckMeshKernelApiFolder)\$(_CheckMeshKernelApiLibFile)"
             ContinueOnError="WarnAndContinue"/> -->

    <!-- because gridgeomStateful_dll.dll is redundant (?) and also using MeshKernelApi Check for these files too in the _CheckGridGeomStatefulFolder -->
    <!-- GridEditorPlugin DOES NOT EXISTS IN 2D3D PLUGIN (D3DFMIQ-1279)
	<MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=MeshKernelApi exp file;
                          KeyValue=$(_CheckGridGeomStatefulFolder)\$(_CheckMeshKernelApiExpFile)"
             ContinueOnError="WarnAndContinue"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=MeshKernelApi lib file;
                          KeyValue=$(_CheckGridGeomStatefulFolder)\$(_CheckMeshKernelApiLibFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckMeshKernelApiDllFile>MeshKernelApi.dll</_CheckMeshKernelApiDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckMeshKernelApiDllFile);
                          KeyValue=$(_CheckMeshKernelApiFolder)\$(_CheckMeshKernelApiDllFile);
                          FileVersion=$(_CheckMeshKernelApiDllFileVersion)"
             ContinueOnError="WarnAndContinue"/>-->

    <!-- because gridgeomStateful_dll.dll is redundant (?) and also using MeshKernelApi Check for this file too in the _CheckGridGeomStatefulFolder -->
    <!-- GridEditorPlugin DOES NOT EXISTS IN 2D3D PLUGIN (D3DFMIQ-1279)
	<MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckMeshKernelApiDllFile);
                          KeyValue=$(_CheckGridGeomStatefulFolder)\$(_CheckMeshKernelApiDllFile);
                          FileVersion=$(_CheckGridEditorMeshKernelApiDllFileVersion)"
             ContinueOnError="WarnAndContinue"/> -->
  </Target>


  <Target Name="TargetPluginsFilesAndFoldersSystemTests" DependsOnTargets="TargetSetVersioningForSystemTest">

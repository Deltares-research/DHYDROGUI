  <Target Name="TargetDeltaShellFilesAndFoldersSystemTests" DependsOnTargets="TargetSetVersioningForSystemTest">
    <PropertyGroup>
      <_Package>DeltaShellFiles</_Package>
      <_File>HarvestedDeltaShellFiles_wxs</_File>
      <_VersionsFile>FM_Properties</_VersionsFile>
    </PropertyGroup>

    <!--We know Deltashell folder exist, check for specific files and file versions in the DeltaShell folder-->
    <PropertyGroup>
      <_CheckDeltaShellGuiExeFile>DeltaShell.Gui.exe</_CheckDeltaShellGuiExeFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell Exe Gui file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeFile)"
             ContinueOnError="WarnAndContinue"/>
    <!-- We do not want to check the deltashell version number
	<MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckDeltaShellGuiExeFile);
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeFile);
                          FileVersion=$(_CheckDeltaShellGuiExeFileVersion)"
             ContinueOnError="WarnAndContinue"/> -->


    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigFile>DeltaShell.Gui.exe.config</_CheckDeltaShellGuiExeConfigFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell Exe Gui config file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <CallTarget Targets="CheckDeltaShellExeStartAndRunAndClose"
				Condition="Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeFile)))) AND Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile))))"
				ContinueOnError="WarnAndContinue"/>
	  <CallTarget Targets="CheckDeltaShelGuiExeConfigXML"
				Condition="Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile))))"
				ContinueOnError="WarnAndContinue"/>

    <!--We know Deltashell Gui exist, check for DeltaShell Console executable and config file the DeltaShell folder-->
    <!--Needed for license checking for the DeltaShell console application-->
    <PropertyGroup>
      <_CheckDeltaShellConsoleExeFile>DeltaShell.Console.exe</_CheckDeltaShellConsoleExeFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell Exe Console file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellConsoleExeFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellConsoleExeConfigFile>DeltaShell.Console.exe.config</_CheckDeltaShellConsoleExeConfigFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell Exe Console config file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellConsoleExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>
    <CallTarget Targets="CheckDeltaShellConsoleExeConfigXML"
                Condition="Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellConsoleExeConfigFile))))"
                ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShell_KernelsFolder>$(_CheckDeltaShellFolder)\x64</_CheckDeltaShell_KernelsFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell kernel folder;
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckEc_ModuleDllFile>ec_module.dll</_CheckEc_ModuleDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell kernel folder;
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckEc_ModuleDllFile)"
             ContinueOnError="WarnAndContinue"/>

    <!-- Somehow the kernel team has removed the fileversion..
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckEc_ModuleDllFile);
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckEc_ModuleDllFile);
                          FileVersion=$(_CheckEc_ModuleDllFileVersion)"
             ContinueOnError="WarnAndContinue"/>-->

    <PropertyGroup>
      <_CheckGridGeomDllFile>gridgeom.dll</_CheckGridGeomDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell kernel folder;
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckGridGeomDllFile)"
             ContinueOnError="WarnAndContinue"/>

    <!-- Somehow the kernel team has removed the fileversion..
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckGridGeomDllFile);
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckGridGeomDllFile);
                          FileVersion=$(_CheckGridGeomDllFileVersion)"
             ContinueOnError="WarnAndContinue"/>-->

    <PropertyGroup>
      <_CheckNetCDF4DllFile>netcdf4.dll</_CheckNetCDF4DllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell kernel folder;
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckNetCDF4DllFile)"
             ContinueOnError="WarnAndContinue"/>
    <!-- Somehow the kernel team has removed the fileversion..
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithComparison"
             Properties=" Package=$(_Package);
                          File=$(_VersionsFile);
                          TestTypeName=fileversion;
                          Key=$(_CheckNetCDF4DllFile);
                          KeyValue=$(_CheckDeltaShell_KernelsFolder)\$(_CheckNetCDF4DllFile);
                          FileVersion=$(_CheckNetCDF4DllFileVersion)"
             ContinueOnError="WarnAndContinue"/>-->


    <PropertyGroup>
      <_CheckDelftToolsHydroDllFile>DelftTools.Hydro.dll</_CheckDelftToolsHydroDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DelftTools Hydro dll file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDelftToolsHydroDllFile)"
             ContinueOnError="WarnAndContinue"/>

    <!-- DOES NOT EXISTS IN 2D3D
	<PropertyGroup>
      <_CheckDeltaShellNghsUtilsDllFile>DeltaShell.NGHS.Utils.dll</_CheckDeltaShellNghsUtilsDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell NGHS Utils dll file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellNghsUtilsDllFile)"
             ContinueOnError="WarnAndContinue"/>
     -->
    <PropertyGroup>
      <_CheckDeltaShellNGHSCommonGuiDllFile>DeltaShell.NGHS.Common.Gui.dll</_CheckDeltaShellNGHSCommonGuiDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell NGHS Common Gui dll file;
                          KeyValue=$(_CheckDeltaShellFolder)\$(_CheckDeltaShellNGHSCommonGuiDllFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellNGHSCommonDllFile>DeltaShell.NGHS.Common.dll</_CheckDeltaShellNGHSCommonDllFile>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=$(_Package);
                          File=$(_File);
                          Key=DeltaShell NGHS Common dll file;
                          KeyValue=$(_CheckDeltaShellFolder)\\$(_CheckDeltaShellNGHSCommonDllFile)"
             ContinueOnError="WarnAndContinue"/>
  </Target>

  <Target Name="CheckDeltaShellExeStartAndRunAndClose">
	<PropertyGroup>
      <_CheckDeltaShellGuiExeFile>DeltaShell.Gui.exe</_CheckDeltaShellGuiExeFile>
      <_CheckDeltaShellGuiExeConfigFile>DeltaShell.Gui.exe.config</_CheckDeltaShellGuiExeConfigFile>
      <_CheckDeltaShellGuiTmpLogFile>DeltaShell.Gui.exe.log</_CheckDeltaShellGuiTmpLogFile>
      <_ValueToCheck>All is fine</_ValueToCheck>
    </PropertyGroup>
    <Delete Files="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)"
			ContinueOnError="true" />
	<Message Importance="high"
			Text="Copy original $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile) to $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile).org"/>
    <Copy 	SourceFiles="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
			DestinationFiles="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile).org"
			ContinueOnError="true" />

    <Message Importance="high"
			Text="Update log location of deltashell logfile in $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile) to $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)"/>
    <XmlPoke
      XmlInputPath="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
      Value="&lt;file value='$(_CheckDeltaShellGuiTmpLogFile)' type='log4net.Util.PatternString'/&gt;&lt;layout type='log4net.Layout.PatternLayout'&gt;&lt;conversionPattern value=&quot;%25date [%thread] %-5level %logger.%M - %message%newline&quot; /&gt;&lt;/layout&gt; "
      Query="/configuration/log4net/appender[@name='fileAppender']"
      />
    <Message Importance="high"
			Text="When starting DeltaShell do not show splashscreen"/>
    <XmlPoke
      XmlInputPath="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
      Value="False"
      Query="/configuration/userSettings/DeltaShell.Gui.Properties.Settings/setting[@name='ShowStartUpScreen']/value"
      />
	<XmlPoke
      XmlInputPath="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
      Value="False"
      Query="/configuration/userSettings/DeltaShell.Gui.Properties.Settings/setting[@name='showSplashScreen']/value"
      />
    <Message Importance="high"
			Text="Start $(_CheckDeltaShellGuiExeFile), run/execute a command line script and exit with timeout of 25sec (without changing the key for licensecheck)"
			Condition=" '$(BUILD_NUMBER)' != '' "/>

    <Exec 	Command="$(_CheckDeltaShellGuiExeFile) -c &quot;print('$(_ValueToCheck)');Gui.Exit();&quot;"
			Timeout="25000"
			ContinueOnError="ErrorAndContinue"
			WorkingDirectory="$(_CheckDeltaShellFolder)"
			IgnoreStandardErrorWarningFormat="true"
			Condition=" '$(BUILD_NUMBER)' != '' "
			/>

    <ReadLinesFromFile File="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Lines" ItemName="FileContents" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <ErrorText>ERROR</ErrorText>
    </PropertyGroup>
    <PropertyGroup>
      <AllLines>@(FileContents)</AllLines>
    </PropertyGroup>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
            Targets="TeamcityTemplateOutputCheckWithExpectation"
            Properties=" Package=DeltaShellExe;
                         File=DeltaShell_exe;
                         Key=Execution DeltaShell;
                         KeyValue=$(AllLines.Contains($(ErrorText)));
						 Condition=$(AllLines.Contains($(ErrorText)));
						 TestTypeName=Functioning;
						 ExpectedValue=false"
            ContinueOnError="WarnAndContinue"
			Condition=" '$(BUILD_NUMBER)' != '' "/>

	<Message Importance="high"
			Text="Failed DeltaShell exe run action because : $(AllLines)"
			Condition=" '$(BUILD_NUMBER)' != '' AND $(AllLines.Contains($(ErrorText)))"/>

    <!-- <Error 	Condition="$(AllLines.Contains($(ErrorText)))"  -->
			<!-- Text="Execution returned with an error."  -->
			<!-- ContinueOnError="ErrorAndContinue" /> -->

	<CreateProperty Value="true"
                    Condition="'@(FileContents->Count())' &lt; 4 AND '$(BUILD_NUMBER)' != ''" ContinueOnError="ErrorAndContinue">
      <Output TaskParameter="Value" PropertyName="_LicenseIsNotPresent" />
    </CreateProperty>
	<CreateProperty Value="false"
                    Condition="'@(FileContents->Count())' &gt;= 3 AND '$(BUILD_NUMBER)' != ''" ContinueOnError="ErrorAndContinue">
      <Output TaskParameter="Value" PropertyName="_LicenseIsNotPresent" />
    </CreateProperty>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
            Targets="TeamcityTemplateOutputCheckWithExpectation"
            Properties=" Package=DeltaShellExe;
                         File=DeltaShell_exe;
                         Key=Deltashell License;
                         KeyValue=$(_LicenseIsNotPresent);
						 Condition=$(_LicenseIsNotPresent);
						 TestTypeName=Functioning;
						 ExpectedValue=false"
            ContinueOnError="WarnAndContinue"
			Condition=" '$(BUILD_NUMBER)' != '' "/>

	<Message Importance="high"
			Text="Failed DeltaShell License check action because : $(AllLines)"
			Condition=" '$(BUILD_NUMBER)' != '' AND $(_LicenseIsNotPresent)"/>

	<ReadLinesFromFile File="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)" Condition=" '$(BUILD_NUMBER)' != '' AND $(_LicenseIsNotPresent)" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Lines" ItemName="FileConfigContents" />
    </ReadLinesFromFile>

	<PropertyGroup>
      <AllLines>@(FileConfigContents)</AllLines>
    </PropertyGroup>

	<Message Importance="high"
			Text="Failed DeltaShell License check action, current DeltaShell.Gui.Exe.Config xml : $(AllLines)"
			Condition=" '$(BUILD_NUMBER)' != '' AND $(_LicenseIsNotPresent)"/>

    <!-- <Error 	Text="Error! License not installed?"  -->
			<!-- Condition="'@(FileContents->Count())' &lt; 3"  -->
			<!-- ContinueOnError="ErrorAndContinue"/> -->
    <XmlPoke
      XmlInputPath="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
      Value="false"
      Query="/configuration/appSettings/add[@key='checkForRegistration']/@value"
    />
    <Delete Files="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)"
			ContinueOnError="ErrorAndContinue"/>
    <Message Importance="high"
			Text="Start $(_CheckDeltaShellGuiExeFile), run/execute a command line script and exit with timeout of 10sec (with changing the key for licensecheck to false)"/>
	<Exec 	Command="$(_CheckDeltaShellGuiExeFile) -c &quot;print('$(_ValueToCheck)');Gui.Exit();&quot;"
			Timeout="25000"
			ContinueOnError="ErrorAndContinue"
			WorkingDirectory="$(_CheckDeltaShellFolder)"
			IgnoreStandardErrorWarningFormat="true"/>
    <ReadLinesFromFile File="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Lines" ItemName="FileContents2" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <AllLines>@(FileContents2)</AllLines>
    </PropertyGroup>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
            Targets="TeamcityTemplateOutputCheckWithExpectation"
            Properties=" Package=DeltaShellExe;
                         File=DeltaShell_exe;
                         Key=Execution DeltaShell;
                         KeyValue=$(AllLines.Contains($(ErrorText)));
						 Condition=$(AllLines.Contains($(ErrorText)));
						 TestTypeName=Functioning;
						 ExpectedValue=false"
            ContinueOnError="WarnAndContinue"/>

	<Message Importance="high"
			Text="Failed DeltaShell exe run action 2 because : $(AllLines)"
			Condition=" '$(BUILD_NUMBER)' != '' AND $(AllLines.Contains($(ErrorText)))"/>

    <!-- <Error Condition="$(AllLines.Contains($(ErrorText)))" Text="Execution returned with an error." ContinueOnError="ErrorAndContinue" /> -->
	<CreateProperty Value="true"
                    Condition="'@(FileContents2->Count())' &lt; 3" ContinueOnError="ErrorAndContinue">
      <Output TaskParameter="Value" PropertyName="_LicenseIsNotPresent2" />
    </CreateProperty>
	<CreateProperty Value="false"
                    Condition="'@(FileContents2->Count())' &gt; 2" ContinueOnError="ErrorAndContinue">
      <Output TaskParameter="Value" PropertyName="_LicenseIsNotPresent2" />
    </CreateProperty>
	<MsBuild Projects="$(MSBuildProjectFullPath)"
            Targets="TeamcityTemplateOutputCheckWithExpectation"
            Properties=" Package=DeltaShellExe;
                         File=DeltaShell_exe;
                         Key=Deltashell License;
                         KeyValue=$(_LicenseIsNotPresent2);
						 Condition=$(_LicenseIsNotPresent2);
						 TestTypeName=Functioning;
						 ExpectedValue=false"
            ContinueOnError="WarnAndContinue"/>

    <!-- <Error Text="Error! License not installed or something with this file?" Condition="'@(FileContents2->Count())' &lt; 3" ContinueOnError="ErrorAndContinue"/> -->

	<!-- <CreateProperty Value="true" -->
                    <!-- Condition="'$(AllLines.Contains($(_ValueToCheck)))'" ContinueOnError="ErrorAndContinue"> -->
      <!-- <Output TaskParameter="Value" PropertyName="_ValueIsPresent" /> -->
    <!-- </CreateProperty> -->
    <!-- <Error Condition="$(_ValueIsPresent) != 'true'" Text="Execution of $(_CheckDeltaShellGuiExeFile) went wrong." ContinueOnError="ErrorAndContinue" /> -->

	<MsBuild Projects="$(MSBuildProjectFullPath)"
            Targets="TeamcityTemplateOutputCheckWithExpectation"
            Properties=" Package=DeltaShellExe;
                         File=DeltaShell_exe;
                         Key=Deltashell Start_Run_Exit;
                         KeyValue=!$(AllLines.Contains($(_ValueToCheck)));
						 Condition=!$(AllLines.Contains($(_ValueToCheck)));
						 TestTypeName=Functioning;
						 ExpectedValue=true"
            ContinueOnError="WarnAndContinue"/>

    <!-- <XmlPoke -->
      <!-- XmlInputPath="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)" -->
      <!-- Value="true" -->
      <!-- Query="/configuration/appSettings/add[@key='checkForRegistration']/@value" -->
    <!-- /> -->


	<Message Importance="high"
			Text="Deleting custom modified $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile) which will be replaced by ORIGINAL $(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile).org"/>
	<Delete Files="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiExeConfigFile)"
			ContinueOnError="ErrorAndContinue"
			Condition="Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile).org)))" />
	<Move
      SourceFiles="$([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile).org))"
      DestinationFiles="$([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile)))"
      ContinueOnError="ErrorAndContinue"
      Condition="Exists($([System.IO.Path]::Combine($(_CheckDeltaShellFolder), $(_CheckDeltaShellGuiExeConfigFile).org)))" />

	<Delete Files="$(_CheckDeltaShellFolder)\$(_CheckDeltaShellGuiTmpLogFile)"
			ContinueOnError="ErrorAndContinue" />


  </Target>

  <Target Name="CheckDeltaShelGuiExeConfigXML">
    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigFile>$(_CheckDeltaShellFolder)\DeltaShell.Gui.exe.config</_CheckDeltaShellGuiExeConfigFile>
    </PropertyGroup>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>applicationName</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>$(ApplicationName)</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>distributionName</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>$(DistributionName)</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>checkForRegistration</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>true</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>publicReleaseVersion</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue Condition="'$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">2024.03.$(BUILD_NUMBER)</_CheckDeltaShellGuiExeConfigExpectedValue>
      <_CheckDeltaShellGuiExeConfigExpectedValue Condition="'$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">2024.03</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>copyright</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>Â© Deltares 2024</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>log4net</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>INFO</_CheckDeltaShellGuiExeConfigExpectedValue>
      <_CheckDeltaShellGuiExeConfigQuery>/configuration/log4net/root/level/@value</_CheckDeltaShellGuiExeConfigQuery>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          Query=$(_CheckDeltaShellGuiExeConfigQuery);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaShellGuiExeConfigSetting>language</_CheckDeltaShellGuiExeConfigSetting>
      <_CheckDeltaShellGuiExeConfigExpectedValue>en-US</_CheckDeltaShellGuiExeConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckDeltaShellGuiExeConfigSetting);
                          xmlKeyExpectedValue=$(_CheckDeltaShellGuiExeConfigExpectedValue);
                          CheckDeltaShellGuiExeConfigFile=$(_CheckDeltaShellGuiExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>
  </Target>

  <Target Name="CheckDeltaShellConsoleExeConfigXML">
    <PropertyGroup>
      <_CheckDeltaShellConsoleExeConfigFile>$(_CheckDeltaShellFolder)\DeltaShell.Console.exe.config</_CheckDeltaShellConsoleExeConfigFile>
    </PropertyGroup>
    <PropertyGroup>
      <_CheckConfigSetting>checkForRegistration</_CheckConfigSetting>
      <_CheckConfigExpectedValue>true</_CheckConfigExpectedValue>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputDeltaShellConsoleExeConfigContentCheck"
             Properties=" xmlKey=$(_CheckConfigSetting);
                          xmlKeyExpectedValue=$(_CheckConfigExpectedValue);
                          CheckDeltaShellConsoleExeConfigFile=$(_CheckDeltaShellConsoleExeConfigFile)"
             ContinueOnError="WarnAndContinue"/>
  </Target>

  <Target Name="TargetShortCutsSystemTests">
    <Message Text="Checking shortcuts" Importance="high"/>
    <PropertyGroup>
      <_CheckDeltaShellStartMenuFolderShortCut>$(ProgramData)\Microsoft\Windows\Start Menu\Programs\Deltares $(ProductName)</_CheckDeltaShellStartMenuFolderShortCut>
      <_CheckDeltaShellStartMenuFolderDeltaShellExeShortCut Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(_CheckDeltaShellStartMenuFolderShortCut)\$(ProductName).lnk</_CheckDeltaShellStartMenuFolderDeltaShellExeShortCut>
      <_CheckDeltaShellStartMenuFolderDeltaShellExeShortCut Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(_CheckDeltaShellStartMenuFolderShortCut)\$(ProductName) ($(BUILD_NUMBER)).lnk</_CheckDeltaShellStartMenuFolderDeltaShellExeShortCut>
      <_CheckDeltaShellStartMenuFolderDeltaShellExeShortCutName>DeltaShell Start Menu Folder DeltaShell Exe ShortCut</_CheckDeltaShellStartMenuFolderDeltaShellExeShortCutName>
      <_CheckDeltaShellDesktopShortCut Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(ALLUSERSPROFILE)\Desktop\$(ProductName).lnk</_CheckDeltaShellDesktopShortCut>
      <_CheckDeltaShellDesktopShortCut Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(ALLUSERSPROFILE)\Desktop\$(ProductName) ($(BUILD_NUMBER)).lnk</_CheckDeltaShellDesktopShortCut>
      <_CheckDeltaShellDesktopShortCutName>Desktop DeltaShell Exe ShortCut</_CheckDeltaShellDesktopShortCutName>
    </PropertyGroup>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputCheckWithExpectation"
             Properties=" Package=Shortcuts;
                          File=Product_wxs;
                          Key=DeltaShell Start Menu Folder;
                          KeyValue=$(_CheckDeltaShellStartMenuFolderShortCut);"
             ContinueOnError="WarnAndContinue"/>


    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputShortcutCheck"
             Properties=" File=Product_wxs;
                          ShortCutName=$(_CheckDeltaShellStartMenuFolderDeltaShellExeShortCutName);
                          ShortCut=$(_CheckDeltaShellStartMenuFolderDeltaShellExeShortCut)"
             ContinueOnError="WarnAndContinue"/>

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputShortcutCheck"
             Properties=" File=Product_wxs;
                          ShortCutName=$(_CheckDeltaShellDesktopShortCutName);
                          ShortCut=$(_CheckDeltaShellDesktopShortCut)"
             ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaresStartMenuFolderUninstallProductShortCut Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(_CheckDeltaShellStartMenuFolderShortCut)\Uninstall $(ProductName).lnk</_CheckDeltaresStartMenuFolderUninstallProductShortCut>
      <_CheckDeltaresStartMenuFolderUninstallProductShortCut Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(_CheckDeltaShellStartMenuFolderShortCut)\Uninstall $(ProductName) ($(BUILD_NUMBER)).lnk</_CheckDeltaresStartMenuFolderUninstallProductShortCut>
      <_CheckDeltaresStartMenuFolderUninstallProductShortCutName>$(ProductName) Start Menu Folder Uninstall $(ProductName) ShortCut</_CheckDeltaresStartMenuFolderUninstallProductShortCutName>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputShortcutCheck" Properties="File=Product_wxs;ShortCutName=$(_CheckDeltaresStartMenuFolderUninstallProductShortCutName);ShortCut=$(_CheckDeltaresStartMenuFolderUninstallProductShortCut);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcut>$(_CheckDeltaShellStartMenuFolderShortCut)\D-Flow Flexible Mesh User Manual.lnk</_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcut>
      <_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcutName>$(ProductName) Start Menu Folder D-Flow Flexible Mesh User Manual ShortCut</_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcutName>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputShortcutCheck" Properties="File=FMManualShortcuts_wxi;ShortCutName=$(_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcutName);ShortCut=$(_CheckDeltaresStartMenuFolderDFlowFMTechnicalReferenceShortcut);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>


  <Target Name="TargetRegistrySystemTests">
    <PropertyGroup>
      <_Package>Registry</_Package>
    </PropertyGroup>

    <PropertyGroup>
      <_File>HarvestFilesTransform_xsl</_File>
      <_DeltaShellRegistryKey>HKEY_LOCAL_MACHINE\SOFTWARE\Deltares\DeltaShell\Capabilities</_DeltaShellRegistryKey>
      <_Check_DeltaShellRegistryKey>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey)', 'ApplicationDescription', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey>

      <_Check_DeltaShellRegistryKey1Name>ApplicationDescription</_Check_DeltaShellRegistryKey1Name>
      <_Check_DeltaShellRegistryKey1>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey)', '$(_Check_DeltaShellRegistryKey1Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey1>
      <_Check_DeltaShellRegistryKey1ExpectedValue>DeltaShell</_Check_DeltaShellRegistryKey1ExpectedValue>

      <_Check_DeltaShellRegistryKey2Name>ApplicationName</_Check_DeltaShellRegistryKey2Name>
      <_Check_DeltaShellRegistryKey2>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey)', '$(_Check_DeltaShellRegistryKey2Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey2>
      <_Check_DeltaShellRegistryKey2ExpectedValue>$(_Check_DeltaShellRegistryKey1ExpectedValue)</_Check_DeltaShellRegistryKey2ExpectedValue>

      <_DeltaShellRegistryKey2>$(_DeltaShellRegistryKey)\FileAssociations</_DeltaShellRegistryKey2>
      <_Check_DeltaShellRegistryKey3Name>.dsproj</_Check_DeltaShellRegistryKey3Name>
      <_Check_DeltaShellRegistryKey3>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey2)', '$(_Check_DeltaShellRegistryKey3Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey3>
      <_Check_DeltaShellRegistryKey3ExpectedValue>DeltaShell.ProjectFile</_Check_DeltaShellRegistryKey3ExpectedValue>

      <_DeltaShellRegistryKey3>$(_DeltaShellRegistryKey)\MIMEAssociations</_DeltaShellRegistryKey3>
      <_Check_DeltaShellRegistryKey4Name>application/dsproj</_Check_DeltaShellRegistryKey4Name>
      <_Check_DeltaShellRegistryKey4>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey3)', '$(_Check_DeltaShellRegistryKey4Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey4>
      <_Check_DeltaShellRegistryKey4ExpectedValue>$(_Check_DeltaShellRegistryKey3ExpectedValue)</_Check_DeltaShellRegistryKey4ExpectedValue>

      <_DeltaShellRegistryKey4>HKEY_LOCAL_MACHINE\SOFTWARE\RegisteredApplications</_DeltaShellRegistryKey4>
      <_Check_DeltaShellRegistryKey5Name>DeltaShell</_Check_DeltaShellRegistryKey5Name>
      <_Check_DeltaShellRegistryKey5>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey4)', '$(_Check_DeltaShellRegistryKey5Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey5>
      <_Check_DeltaShellRegistryKey5ExpectedValue>SOFTWARE\Deltares\DeltaShell\Capabilities</_Check_DeltaShellRegistryKey5ExpectedValue>

      <_DeltaShellRegistryKey5>HKEY_LOCAL_MACHINE\SOFTWARE\Classes\Applications\DeltaShell.Gui.exe\shell\open</_DeltaShellRegistryKey5>
      <_Check_DeltaShellRegistryKey6Name>FriendlyAppName</_Check_DeltaShellRegistryKey6Name>
      <_Check_DeltaShellRegistryKey6>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey5)', '$(_Check_DeltaShellRegistryKey6Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey6>
      <_Check_DeltaShellRegistryKey6ExpectedValue>$(_Check_DeltaShellRegistryKey1ExpectedValue)</_Check_DeltaShellRegistryKey6ExpectedValue>

      <_DeltaShellRegistryKey6>HKEY_LOCAL_MACHINE\SOFTWARE\Classes\DeltaShell.ProjectFile</_DeltaShellRegistryKey6>
      <_Check_DeltaShellRegistryKey7Name>FriendlyTypeName</_Check_DeltaShellRegistryKey7Name>
      <_Check_DeltaShellRegistryKey7>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey6)', '$(_Check_DeltaShellRegistryKey7Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey7>
      <_Check_DeltaShellRegistryKey7ExpectedValue>$(_Check_DeltaShellRegistryKey1ExpectedValue)</_Check_DeltaShellRegistryKey7ExpectedValue>

      <_DeltaShellRegistryKey7>HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\DeltaShell.Gui.exe</_DeltaShellRegistryKey7>
      <_Check_DeltaShellRegistryKey8Name>Path</_Check_DeltaShellRegistryKey8Name>
      <_Check_DeltaShellRegistryKey8>$([MSBuild]::GetRegistryValueFromView('$(_DeltaShellRegistryKey7)', '$(_Check_DeltaShellRegistryKey8Name)', null, RegistryView.Registry64, RegistryView.Registry32))</_Check_DeltaShellRegistryKey8>
      <!--<_Check_DeltaShellRegistryKey8>$(registry:HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\DeltaShell.Gui.exe@$(_Check_DeltaShellRegistryKey8Name))</_Check_DeltaShellRegistryKey8>-->
      <_Check_DeltaShellRegistryKey8ExpectedValue Condition=" '$(BUILD_NUMBER)' == '' OR '$(Configuration)' == 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName)\bin\</_Check_DeltaShellRegistryKey8ExpectedValue>
      <_Check_DeltaShellRegistryKey8ExpectedValue Condition=" '$(BUILD_NUMBER)' != '' AND '$(Configuration)' != 'Release'">$(MSBuildProjectDirectory)\$(OutputPath)$(MyCultureOutputFolder)install\$(ProductName) ($(BUILD_NUMBER))\bin\</_Check_DeltaShellRegistryKey8ExpectedValue>

      <_Check_DeltaShellRegistryKey10Name>Class root projectfile</_Check_DeltaShellRegistryKey10Name>
      <_Check_DeltaShellRegistryKey10>$(registry:HKEY_CLASSES_ROOT\DeltaShell.dsproj)</_Check_DeltaShellRegistryKey10>
      <_Check_DeltaShellRegistryKey10ExpectedValue>DeltaShell data project file</_Check_DeltaShellRegistryKey10ExpectedValue>

      <_Check_DeltaShellRegistryKey11Name>Class root projectfile ext</_Check_DeltaShellRegistryKey11Name>
      <_Check_DeltaShellRegistryKey11>$(registry:HKEY_CLASSES_ROOT\.dsproj)</_Check_DeltaShellRegistryKey11>
      <_Check_DeltaShellRegistryKey11ExpectedValue>DeltaShell.dsproj</_Check_DeltaShellRegistryKey11ExpectedValue>
    </PropertyGroup>

    <!--<Message Text="##teamcity[testStarted name='Detecting Registry of DeltaShell ApplicationDescription $(CheckingFor)']" Importance="high" />
    <Message Importance="high" Text="Registry key DeltaShell Registry of ApplicationDescription is $(CheckingFor) with value '$(_Check_DeltaShellRegistryKey)'"/>
    <Message Text="##teamcity[testFailed name='Detecting Registry of DeltaShell ApplicationDescription $(CheckingFor)' message='Registry key DeltaShell ApplicationDescription is $(CheckingFor) with value $(_Check_DeltaShellRegistryKey)']" Importance="high" Condition="!('$(_Check_DeltaShellRegistryKey)' != '' AND $(_Check_DeltaShellRegistryKey) == 'DeltaShell' AND !$(ConditionState)) AND !('$(_Check_DeltaShellRegistryKey)' == '' AND '$(ConditionState)')" />
    <Message Text="##teamcity[testFinished name='Detecting Registry of DeltaShell ApplicationDescription $(CheckingFor)']" Importance="high" />-->

    <MsBuild Projects="$(MSBuildProjectFullPath)"
             Targets="TeamcityTemplateOutputRegistryCheckWithExpectation"
             Properties="RegistryKey=$(_Check_DeltaShellRegistryKey1Name);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_Check_DeltaShellRegistryKey1);ExpectedValue=$(_Check_DeltaShellRegistryKey1ExpectedValue);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>


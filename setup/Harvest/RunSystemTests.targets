    <Message Text="Checking registry using HKEY_LOCAL_MACHINE\SOFTWARE\Deltares\$(ProductName)\$(MyProductCode)." Importance="high" />

    <PropertyGroup>
      <_File>DeltaShell_Customizations_wxi</_File>
      <_BaseRegistryKey>HKEY_LOCAL_MACHINE\SOFTWARE\Deltares\$(ProductName)\$(ProductCode)</_BaseRegistryKey>
    </PropertyGroup>

    <PropertyGroup>
      <_CheckRegKeyInstalledPluginManualsKey>installedPluginManuals</_CheckRegKeyInstalledPluginManualsKey>
      <_CheckRegKeyInstalledPluginManuals>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyInstalledPluginManualsKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyInstalledPluginManuals>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyInstalledPluginManualsKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyInstalledPluginManuals);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckRegKeyInstalledManualsShortcutFolderKey>installedManualsShortcutFolder</_CheckRegKeyInstalledManualsShortcutFolderKey>
      <_CheckRegKeyInstalledManualsShortcutFolder>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyInstalledManualsShortcutFolderKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyInstalledManualsShortcutFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyInstalledManualsShortcutFolderKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyInstalledManualsShortcutFolder);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckRegKeyinstalledDSUMManualShortcutFolderKey>installedDSUMManualShortcutFolder</_CheckRegKeyinstalledDSUMManualShortcutFolderKey>
      <_CheckRegKeyinstalledDSUMManualShortcutFolder>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyinstalledDSUMManualShortcutFolderKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyinstalledDSUMManualShortcutFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyinstalledDSUMManualShortcutFolderKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyinstalledDSUMManualShortcutFolder);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckRegKeyinstalledUtilitiesShortcutFolderKey>installedUtilitiesShortcutFolder</_CheckRegKeyinstalledUtilitiesShortcutFolderKey>
      <_CheckRegKeyinstalledUtilitiesShortcutFolder>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyinstalledUtilitiesShortcutFolderKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyinstalledUtilitiesShortcutFolder>
    </PropertyGroup>
    <MsBuild 	Projects="$(MSBuildProjectFullPath)"
				Targets="TeamcityTemplateOutputRegistryCheck"
				Properties="RegistryKey=$(_CheckRegKeyinstalledUtilitiesShortcutFolderKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyinstalledUtilitiesShortcutFolder);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)"
				Condition="'$(MyCultureOutputFolder)' != 'fmo\'"
				ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_File>Extras_wxi</_File>
    </PropertyGroup>

    <PropertyGroup>
      <_CheckRegKeyinstalledFMExtrasKey>installedFMExtras</_CheckRegKeyinstalledFMExtrasKey>
      <_CheckRegKeyinstalledFMExtras>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyinstalledFMExtrasKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyinstalledFMExtras>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyinstalledFMExtrasKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyinstalledFMExtras);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_File>Product_wxi</_File>
    </PropertyGroup>

    <PropertyGroup>
      <_CheckRegKeyinstalledDeltaresShortcutFolderKey>installedDeltaresShortcutFolder</_CheckRegKeyinstalledDeltaresShortcutFolderKey>
      <_CheckRegKeyinstalledDeltaresShortcutFolder>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyinstalledDeltaresShortcutFolderKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyinstalledDeltaresShortcutFolder>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyinstalledDeltaresShortcutFolderKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyinstalledDeltaresShortcutFolder);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckRegKeyinstalledDeltaShellGuiExeConfigKey>installedDeltaShellGuiExeConfig</_CheckRegKeyinstalledDeltaShellGuiExeConfigKey>
      <_CheckRegKeyinstalledDeltaShellGuiExeConfig>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyinstalledDeltaShellGuiExeConfigKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyinstalledDeltaShellGuiExeConfig>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyinstalledDeltaShellGuiExeConfigKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyinstalledDeltaShellGuiExeConfig);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

    <PropertyGroup>
      <_CheckRegKeyInstalledUninstallerShortcutKey>InstalledUninstallerShortcut</_CheckRegKeyInstalledUninstallerShortcutKey>
      <_CheckRegKeyInstalledUninstallerShortcut>$([MSBuild]::GetRegistryValueFromView('$(_BaseRegistryKey)', '$(_CheckRegKeyInstalledUninstallerShortcutKey)', null, RegistryView.Registry64, RegistryView.Registry32))</_CheckRegKeyInstalledUninstallerShortcut>
    </PropertyGroup>
    <MsBuild Projects="$(MSBuildProjectFullPath)" Targets="TeamcityTemplateOutputRegistryCheck" Properties="RegistryKey=$(_CheckRegKeyInstalledUninstallerShortcutKey);Package=$(_Package);File=$(_File);RegistryKeyValue=$(_CheckRegKeyInstalledUninstallerShortcut);CheckingFor=$(CheckingFor);ConditionState=$(ConditionState)" ContinueOnError="WarnAndContinue"/>

  </Target>

  <Target Name="TeamcityTemplateOutputDeltaShellConsoleExeConfigContentCheck">
    <PropertyGroup>
      <_Query Condition="'$(Query)' == ''">/configuration/appSettings/add[@key='$(xmlKey)']/@value</_Query>
      <_Query Condition="'$(Query)' != ''">$(Query)</_Query>
    </PropertyGroup>
    <XmlPeek XmlInputPath="$(CheckDeltaShellConsoleExeConfigFile)" Query="$(_Query)" Condition="Exists('$(CheckDeltaShellConsoleExeConfigFile)')" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Result" ItemName="xmlKeyValue" />
    </XmlPeek>

    <Message Text="Using check for setting $(xmlKey) in $(CheckDeltaShellConsoleExeConfigFile)." Importance="high" />
    <Message Text="##teamcity[testStarted name='XMLFileContent.GuiConfigXml_wxi.DeltaShellConsoleExe config file $(xmlKey) value']" Importance="high" />
    <Message Text="Detecting DeltaShell.Console.exe.config file $(xmlKey) value at $(CheckDeltaShellGuiConsoleConfigFile) with value = @(xmlKeyValue)." Importance="high" />
    <Error Text="Detected DeltaShell.Console.exe.config file $(xmlKey) value at $(CheckDeltaShellGuiConsoleConfigFile) with value @(xmlKeyValue) but expected was $(xmlKeyExpectedValue)." Condition="'@(xmlKeyValue)' != '$(xmlKeyExpectedValue)'" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed
             name='XMLFileContent.GuiConfigXml_wxi.DeltaShellConsoleExe config file $(xmlKey) value'
             message='The key check for $(xmlKey) should be $(xmlKeyExpectedValue) but is @(xmlKeyValue)']"
             Importance="high"
             Condition="'@(xmlKeyValue)' != '$(xmlKeyExpectedValue)'"/>
    <Message Text="##teamcity[testFinished name='XMLFileContent.GuiConfigXml_wxi.DeltaShellConsoleExe config file $(xmlKey) value']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputDeltaShellExeConfigContentCheck">
    <PropertyGroup>
      <_Query Condition="'$(Query)' == ''">/configuration/appSettings/add[@key='$(xmlKey)']/@value</_Query>
      <_Query Condition="'$(Query)' != ''">$(Query)</_Query>
    </PropertyGroup>
    <XmlPeek XmlInputPath="$(CheckDeltaShellGuiExeConfigFile)" Query="$(_Query)" Condition="Exists('$(CheckDeltaShellGuiExeConfigFile)')" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Result" ItemName="xmlKeyValue" />
    </XmlPeek>

    <Message Text="Using check for setting $(xmlKey) in $(CheckDeltaShellGuiExeConfigFile)." Importance="high" />
    <Message Text="##teamcity[testStarted name='XMLFileContent.GuiConfigXml_wxi.DeltaShellGuiExe config file $(xmlKey) value']" Importance="high" />
    <Message Text="Detecting DeltaShell.Gui.exe.config file $(xmlKey) value at $(CheckDeltaShellGuiExeConfigFile) with value = @(xmlKeyValue)." Importance="high" />
    <Error Text="Detected DeltaShell.Gui.exe.config file $(xmlKey) value at $(CheckDeltaShellGuiExeConfigFile) with value @(xmlKeyValue) but expected was $(xmlKeyExpectedValue)." Condition="'@(xmlKeyValue)' != '$(xmlKeyExpectedValue)'" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed
             name='XMLFileContent.GuiConfigXml_wxi.DeltaShellGuiExe config file $(xmlKey) value'
             message='The key check for $(xmlKey) should be $(xmlKeyExpectedValue) but is @(xmlKeyValue)']"
             Importance="high"
             Condition="'@(xmlKeyValue)' != '$(xmlKeyExpectedValue)'"/>
    <Message Text="##teamcity[testFinished name='XMLFileContent.GuiConfigXml_wxi.DeltaShellGuiExe config file $(xmlKey) value']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputShortcutCheck">
    <Message Text="##teamcity[testStarted name='Shortcuts.$(File).$(ShortCutName) $(CheckingFor)']" Importance="high" />
    <Message Text="Detecting $(ShortCutName) $(CheckingFor) at $(ShortCut)." Importance="high" />
    <Error Text="Detecting $(ShortCutName) not $(CheckingFor) at $(ShortCut)." Condition="Exists('$(ShortCut)') == $(ConditionState)" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed name='Shortcuts.$(File).$(ShortCut) $(CheckingFor)' message='The shortcut $(ShortCut) should be $(CheckingFor)']" Importance="high" Condition="Exists('$(ShortCut)') == $(ConditionState)"/>
    <Message Text="##teamcity[testFinished name='Shortcuts.$(File).$(ShortCutName) $(CheckingFor)']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputRegistryCheck">
    <PropertyGroup>
      <_Condition Condition="!('$(RegistryKeyValue)' != '' AND $(RegistryKeyValue) == '1' AND !$(ConditionState)) AND !('$(RegistryKeyValue)' == '' AND '$(ConditionState)')">true</_Condition>
      <_Condition Condition="'$(_Condition)' == ''">false</_Condition>
    </PropertyGroup>

    <Message Text="##teamcity[testStarted name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)']" Importance="high" />
    <Message Importance="high" Text="Registry key $(RegistryKey) is not $(CheckingFor) with value '$(RegistryKeyValue)'"/>
    <Error Text="Registry key $(RegistryKey) is not $(CheckingFor) with value '$(RegistryKeyValue)'" Condition="$(_Condition)" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)' message='Registry key $(RegistryKey) is $(CheckingFor)']" Importance="high"
             Condition="$(_Condition)" />
    <Message Text="##teamcity[testFinished name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputRegistryCheckWithExpectation">
    <PropertyGroup>
      <_Condition Condition="!('$(RegistryKeyValue)' != '' AND $(RegistryKeyValue) == '$(ExpectedValue)' AND !$(ConditionState)) AND !('$(RegistryKeyValue)' == '' AND '$(ConditionState)')">true</_Condition>
      <_Condition Condition="'$(_Condition)' == ''">false</_Condition>
    </PropertyGroup>
    <Message Text="##teamcity[testStarted name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)']" Importance="high" />
    <Message Importance="high" Text="Registry key $(RegistryKey) is not $(CheckingFor) has value '$(RegistryKeyValue)'"/>
    <Error Text="Registry key $(RegistryKey) is not $(CheckingFor) has value '$(RegistryKeyValue)'" Condition="$(_Condition)" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)' message='Registry key $(RegistryKey) is $(CheckingFor)' value $(ExpectedValue)]" Importance="high"
             Condition="$(_Condition)" />
    <Message Text="##teamcity[testFinished name='$(Package).$(File).Checking Registry key $(RegistryKey) is $(CheckingFor)']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputCheckWithExpectation">
    <PropertyGroup>
      <_Condition Condition="'$(Condition)' == '' AND Exists($(KeyValue)) == $(ConditionState)">true</_Condition>
      <_Condition Condition="'$(Condition)' == '' AND !(Exists($(KeyValue)) == $(ConditionState))">false</_Condition>
      <_Condition Condition="'$(Condition)' != ''">$(Condition)</_Condition>
      <_TestTypeName Condition="'$(TestTypeName)' == ''">Detecting</_TestTypeName>
      <_TestTypeName Condition="'$(TestTypeName)' != ''">$(TestTypeName)</_TestTypeName>
      <_ExpectedValue Condition="'$(ExpectedValue)' == ''">Exists</_ExpectedValue>
      <_ExpectedValue Condition="'$(ExpectedValue)' != ''">$(ExpectedValue)</_ExpectedValue>
    </PropertyGroup>

    <Message Text="##teamcity[testStarted name='$(Package).$(File).$(_TestTypeName) $(Key) is $(CheckingFor)']" Importance="high" />
    <Message Importance="high" Text="$(_TestTypeName) is $(CheckingFor) with value '$(KeyValue)'"/>
    <Error Text="$(_TestTypeName) $(Key) ($(KeyValue)) is $(CheckingFor) with value '$(_ExpectedValue)' check file : $(File)" Condition="$(_Condition)" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed
              name='$(Package).$(File).$(_TestTypeName) $(Key) is $(CheckingFor)'
              message='$(_TestTypeName) $(Key) is not $(CheckingFor)']"
             Importance="high"
             Condition="$(_Condition)" />
    <Message Text="##teamcity[testFinished name='$(Package).$(File).$(_TestTypeName) $(Key) is $(CheckingFor)']" Importance="high" />
  </Target>

  <Target Name="TeamcityTemplateOutputCheckWithComparison">
    <GetFileVersion AssemblyPath="$(KeyValue)" Condition="Exists('$(KeyValue)')" ContinueOnError="WarnAndContinue">
      <Output TaskParameter="Version" PropertyName="_AssemblyFileVersion" />
    </GetFileVersion>
    <Message Text="##teamcity[testStarted name='$(Package).$(File).$(Key) $(TestTypeName)']" Importance="high" />
    <Message Importance="high" Text="$(Key) ($(KeyValue)) does not Exist" Condition="!Exists('$(KeyValue)')"/>
    <Message Importance="high" Text="$(TestTypeName) is $(_AssemblyFileVersion)'" Condition="Exists('$(KeyValue)')"/>
    <Error Text="$(TestTypeName) of $(Key) ($(KeyValue)) is not $(FileVersion) but is '$(_AssemblyFileVersion)' check file : $(File) or $(Key)" Condition="Exists('$(KeyValue)') AND $(FileVersion) != $(_AssemblyFileVersion)" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed
              type='comparisonFailure'
              name='$(Package).$(File).$(Key) $(TestTypeName)'
              message='$(Key) ($(KeyValue)) $(TestTypeName) is not $(FileVersion) but is $(_AssemblyFileVersion)'
              expected='$(FileVersion)'
              actual='$(_AssemblyFileVersion)']"
             Importance="high"
             Condition="Exists('$(KeyValue)') AND $(FileVersion) != $(_AssemblyFileVersion)"/>
    <Error Text="$(Key) ($(KeyValue)) does not Exist" Condition="!Exists('$(KeyValue)')" ContinueOnError="ErrorAndContinue"/>
    <Message Text="##teamcity[testFailed
              name='$(Package).$(File).$(Key) $(TestTypeName)'
              message='$(Key) ($(KeyValue)) does not exist, can not do version check']"
             Importance="high"
             Condition="!Exists('$(KeyValue)')"/>
    <Message Text="##teamcity[testFinished name='$(Package).$(File).$(Key) $(TestTypeName)']" Importance="high" />
  </Target>
</Project>

        <File Id="pi_diag.xsd" Source="$(var.rtc_xsd_dir)pi_diag.xsd" />
        <File Id="pi_modelparameters.xsd" Source="$(var.rtc_xsd_dir)pi_modelparameters.xsd" />
        <File Id="pi_run.xsd" Source="$(var.rtc_xsd_dir)pi_run.xsd" />
        <File Id="pi_sharedtypes.xsd" Source="$(var.rtc_xsd_dir)pi_sharedtypes.xsd" />
        <File Id="pi_state.xsd" Source="$(var.rtc_xsd_dir)pi_state.xsd" />

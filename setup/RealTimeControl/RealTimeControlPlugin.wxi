        <Component Id="x64_rtc_kernels" Guid="1CE19292-8D7E-4526-95F2-B548D983BC27" >
          <?define x64_rtc_kernels_lib_dir="$(var.rtc_kernels_lib_dir)x64\"?>
          <File Id="x64_rtc_IpOptFSS.dll" Source="$(var.x64_rtc_kernels_lib_dir)IpOptFSS.dll" />
          <File Id="x64_rtc_IpOpt_vc10.dll" Source="$(var.x64_rtc_kernels_lib_dir)IpOpt-vc10.dll" />

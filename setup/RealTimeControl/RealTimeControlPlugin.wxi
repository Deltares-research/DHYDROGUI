        <File Id="rtcPostprocessingConfig.xsd" Source="$(var.rtc_xsd_dir)rtcPostprocessingConfig.xsd" />
        <File Id="rtcRuntimeConfig.xsd" Source="$(var.rtc_xsd_dir)rtcRuntimeConfig.xsd" />
        <File Id="rtcScenarioTreeConfig.xsd" Source="$(var.rtc_xsd_dir)rtcScenarioTreeConfig.xsd" />
        <File Id="rtcsharedtypes.xsd" Source="$(var.rtc_xsd_dir)rtcsharedtypes.xsd" />
        <File Id="rtcStateConfig.xsd" Source="$(var.rtc_xsd_dir)rtcStateConfig.xsd" />
        <File Id="rtctoolsconfig.xsd" Source="$(var.rtc_xsd_dir)rtctoolsconfig.xsd" />
        <File Id="treeVector.xsd" Source="$(var.rtc_xsd_dir)treeVector.xsd" />
        <?undef rtc_xsd_dir ?>
      </Component>
    </Directory>
    
    <Directory Id="rtc_kernel_lib_folder" Name="rtc_kernel">
      <?define rtc_kernels_lib_dir="$(var.rtc_plugin_bin)rtc_kernel\"?>
      <Directory Id="x86_rtc_kernel_lib_folder" Name="x86">
        <?ifndef var.NOKERNELS?>
        <Component Id="x86_rtc_kernels" Guid="16205B1F-4C15-4A85-870C-B9D0134158F7" >
          <?define x86_rtc_kernels_lib_dir="$(var.rtc_kernels_lib_dir)x86\"?>
          <File Id="x86_rtc_IpOptFSS.dll" Source="$(var.x86_rtc_kernels_lib_dir)IpOptFSS.dll" />
          <File Id="x86_rtc_IpOpt_vc10.dll" Source="$(var.x86_rtc_kernels_lib_dir)IpOpt-vc10.dll" />

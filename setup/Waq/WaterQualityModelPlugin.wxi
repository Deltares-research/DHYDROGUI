        <Component Id="DuflowProcessLibraryPlugin_x64" Guid="7A0AEAE4-D3F2-4BB9-BD1E-8AFC41AF56F6">
          <File Id="x64_duflow.dll" Source="$(var.waq_kernel_dir)x64\duflow.dll" />
        </Component>
        <?endif?>
      </Directory>
      
      <Directory Id="Data" Name="Data" >
        <?ifndef var.NOKERNELS?>
        <Directory Id="SubstancesFilesDir" Name="Sobek" />
        <?endif?>
        <Directory Id="Duflow" Name="Duflow" >

<?xml version="1.0" encoding="utf-8"?>
<Include>
  <?include ..\Scripts\WaterQualityScripts.wxi?>
  <?define waq_plugin_bin="$(var.deltashell_output_folder)plugins\DeltaShell.Plugins.DelftModels.WaterQualityModel\"?>
  <Directory Id="DeltaShell.Plugins.WaterQualityModel" Name="DeltaShell.Plugins.WaterQualityModel">
    <Component Id="WaterQualityModelPlugin" Guid="F1D6AEB0-9D12-44BD-BEAF-16341DFB84F8">
      <File Id="DeltaShell.Plugins.DelftModels.WaterQualityModel.dll" Source="$(var.waq_plugin_bin)DeltaShell.Plugins.DelftModels.WaterQualityModel.dll" KeyPath="yes"/>
    </Component>
    
    <Directory Name="waq_kernel" Id="delwaq_kernel_folder">
      <?define waq_kernel_dir="$(var.waq_plugin_bin)\waq_kernel\"?>
      <Directory Name="x64" Id="delwaq_x64_folder">

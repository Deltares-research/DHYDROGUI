<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" namespace="DeltaShell.Plugins.DelftModels.WaterFlowModel.Roughness" assembly="DeltaShell.Plugins.DelftModels.WaterFlowModel">
  <class name="RoughnessSection" table="roughness_section" lazy="false" discriminator-value="roughness_section" >
    <id name="Id" column="id" type="Int64" unsaved-value="0">
      <generator class="increment" />
    </id>
    <discriminator column="type" type="string"/>
    
    <many-to-one name="CrossSectionSectionType" class="DelftTools.Hydro.CrossSections.CrossSectionSectionType, DelftTools.Hydro" />
    <many-to-one name="RoughnessNetworkCoverage" class="DeltaShell.Plugins.DelftModels.WaterFlowModel.Roughness.RoughnessNetworkCoverage, DeltaShell.Plugins.DelftModels.WaterFlowModel" cascade="all" />
    
    <many-to-one name="Network"
                 class="GeoAPI.Extensions.Networks.INetwork,GeoAPI.Extensions"
                 cascade="save-update"
                 not-null="false"
                 lazy="false"/>

    <list name="RoughnessFunctionOfH" access="property" lazy="true" cascade="all">
      <key column="RoughnessSection_roughnessFunctionOfH_id"/>
      <index column="RoughnessSection_roughnessFunctionOfH_index" />
      <one-to-many class="DelftTools.Functions.IFunction, DelftTools.Functions" />
    </list>
    <list name="RoughnessFunctionOfQ" access="property" lazy="true" cascade="all">
      <key column="RoughnessSection_roughnessFunctionOfQ_id"/>
      <index column="RoughnessSection_roughnessFunctionOfQ_index" />
      <one-to-many class="DelftTools.Functions.IFunction, DelftTools.Functions" />
    </list>    

  </class>
</hibernate-mapping>
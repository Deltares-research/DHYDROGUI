<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   auto-import="false"
                   namespace="DeltaShell.Plugins.DelftModels.RealTimeControl.Domain"
                   assembly="DeltaShell.Plugins.DelftModels.RealTimeControl">

  <class name="Setting" lazy="false" table="rtc_settings">
    <id name="Id" column="id" type="Int64" access="property">
      <generator class="increment" />
    </id>
    <property name="Min" column="min" />
    <property name="Max" column="max" />
    <property name="Below" column="below" />
    <property name="Above" column="above" />
    <property name="MaxSpeed" column="maxSpeed" />
  </class>
</hibernate-mapping>
<UserControl x:Class="DeltaShell.Plugins.DelftModels.WaterFlowModel.Gui.Forms.WaterFlowModel1DLateralSourceDataViewWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeltaShell.Plugins.DelftModels.WaterFlowModel.Gui.Forms"
             xmlns:dsswf="clr-namespace:DeltaShell.Plugins.CommonTools.Gui.Forms.Functions;assembly=DeltaShell.Plugins.CommonTools.Gui"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dsf1DDataObjects="clr-namespace:DeltaShell.Plugins.DelftModels.WaterFlowModel.DataObjects;assembly=DeltaShell.Plugins.DelftModels.WaterFlowModel"
             mc:Ignorable="d" 
             d:DesignHeight="300" 
             d:DesignWidth="300">
    <UserControl.DataContext>
        <local:WaterFlowModel1DLateralSourceDataViewWpfViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <ObjectDataProvider MethodName="GetValues"
        ObjectType="{x:Type sys:Enum}"
        x:Key="FlowLateralTypeValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="dsf1DDataObjects:WaterFlowModel1DLateralDataType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider MethodName="GetValues"
        ObjectType="{x:Type sys:Enum}"
        x:Key="SaltLateralTypeValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="dsf1DDataObjects:SaltLateralDischargeType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider MethodName="GetValues"
        ObjectType="{x:Type sys:Enum}"
        x:Key="TemperatureLateralTypeValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="dsf1DDataObjects:TemperatureLateralDischargeType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid>
        <TabControl x:Name="tabControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TabItem Header="Flow Data" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Type" Grid.Row="0" Grid.Column="0"/>
                        <Label Content="Flow [m³/s]" Grid.Row="1"  Grid.Column="0" Visibility="{Binding UseFlowConstantForFlowData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ComboBox Grid.Row="0"  Grid.Column="1" ItemsSource="{Binding Source={StaticResource FlowLateralTypeValues}}" SelectedValue="{Binding LateralDischargeDataType}" SelectionChanged="OnSelectionFlowDataTypeChanged"/>
                        <TextBox Text="{Binding Flow}" PreviewKeyDown="ProhibitSpaceKey" PreviewTextInput="NumberValidationTextBox" Grid.Row="1" Grid.Column="1" Visibility="{Binding UseFlowConstantForFlowData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <WindowsFormsHost local:WindowsFormsHostFunctionView.Data="{Binding WaterFlowModel1DLateralSourceData.Data}"  Grid.Row="1" Visibility="{Binding UseTimeseriesForFlowData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <dsswf:FunctionView/>
                    </WindowsFormsHost>
                </Grid>
            </TabItem>
            <TabItem Header="Salinity Data" Visibility="{Binding SalinityEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Type" Grid.Row="0" Grid.Column="0"/>
                        <Label Content="Concentration [ppt]" Grid.Row="1"  Grid.Column="0" Visibility="{Binding UseConcentrationConstantForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Label Content="Mass [kg/s]" Grid.Row="2"  Grid.Column="0" Visibility="{Binding UseMassConstantForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ComboBox Grid.Row="0"  Grid.Column="1" ItemsSource="{Binding Source={StaticResource SaltLateralTypeValues}}" SelectedValue="{Binding SaltLateralDischargeType}" SelectionChanged="OnSelectionSalinityDataTypeChanged"/>
                        <TextBox Text="{Binding SaltConcentrationConstant}" PreviewKeyDown="ProhibitSpaceKey" PreviewTextInput="NumberValidationTextBox" Grid.Row="1" Grid.Column="1" Visibility="{Binding UseConcentrationConstantForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBox Text="{Binding SaltMassConstant}" PreviewKeyDown="ProhibitSpaceKey" PreviewTextInput="NumberValidationTextBox" Grid.Row="2" Grid.Column="1" Visibility="{Binding UseMassConstantForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <WindowsFormsHost local:WindowsFormsHostFunctionView.Data="{Binding WaterFlowModel1DLateralSourceData.SaltConcentrationTimeSeries}" Grid.Row="1" Visibility="{Binding UseConcentrationTimeseriesForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <dsswf:FunctionView/>
                    </WindowsFormsHost>
                    <WindowsFormsHost local:WindowsFormsHostFunctionView.Data="{Binding WaterFlowModel1DLateralSourceData.SaltMassTimeSeries}" Grid.Row="1" Visibility="{Binding UseMassTimeseriesForSalinityData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <dsswf:FunctionView/>
                    </WindowsFormsHost>
                </Grid>
            </TabItem>
            <TabItem Header="Temperature Data" Visibility="{Binding TemperatureEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Type" Grid.Row="0" Grid.Column="0"/>
                        <Label Content="Temperature [°C]" Grid.Row="1"  Grid.Column="0" Visibility="{Binding UseConstantForTemperatureData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ComboBox Grid.Row="0"  Grid.Column="1" ItemsSource="{Binding Source={StaticResource TemperatureLateralTypeValues}}" SelectedValue="{Binding TemperatureDischargeType}" SelectionChanged="OnSelectionTemperatureDataTypeChanged"/>
                        <TextBox Text="{Binding TemperatureConstant}" PreviewKeyDown="ProhibitSpaceKey" PreviewTextInput="NumberValidationTextBox" Grid.Row="1" Grid.Column="1" Visibility="{Binding UseConstantForTemperatureData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <WindowsFormsHost local:WindowsFormsHostFunctionView.Data="{Binding WaterFlowModel1DLateralSourceData.TemperatureTimeSeries}" Grid.Row="1" Visibility="{Binding UseTimeseriesForTemperatureData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <dsswf:FunctionView/>
                    </WindowsFormsHost>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>


<Project Sdk="Microsoft.NET.Sdk">
	<Import Project="$(SolutionDir)\Build\targets\Base.targets" />
	
	<PropertyGroup>
		<OutputPath>$(SolutionDir)bin\$(Configuration)\plugins\DeltaShell.Plugins.ImportExport.Sobek</OutputPath>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="DeltaShell.Framework" Version="2.0.0.1810" GeneratePathProperty="true">

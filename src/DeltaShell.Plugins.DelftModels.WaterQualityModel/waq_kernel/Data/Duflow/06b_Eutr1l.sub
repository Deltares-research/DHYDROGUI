end-output
output 'denit'
   description   ' kden*tden**(t-20)*kdno/(kdno+O2)'
end-output
output 'oxid'
   description   ' kbod*tbod**(t-20)*O2/(O2+kbodo)'
end-output
output 'conv'
   description   '(1-exp(-5*kbod))'
end-output
output 'u'
   description   ' ABS(Q/As)'
end-output
output 'kmas'
   description   ' 3.94*u**0.5*z**(-0.5)'
end-output
output 'kre'

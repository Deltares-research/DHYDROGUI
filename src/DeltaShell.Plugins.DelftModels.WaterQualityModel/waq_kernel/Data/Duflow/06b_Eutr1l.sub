   description   ' i0/is'
end-output
output 'fl2'
   description   ' 2.71*(exp(-1*ister*exp(-1*Etot*z))-exp(-ister))/('
end-output
output 'ft'
   description   ' tga**(t-20)'
end-output
output 'Groei'
   description   ' umax*fn*fl2*ft'
end-output
output 'Resp'
   description   ' kres*tra**(t-20)+kdie'
end-output
output 'mino'

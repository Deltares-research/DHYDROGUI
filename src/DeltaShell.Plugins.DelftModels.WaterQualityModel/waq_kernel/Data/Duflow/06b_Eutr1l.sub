output 'fdpano'
   description   ' 1/(1+kpip*SS)'
end-output
output 'PORTO'
   description   ' PANORG*fdpano'
end-output
output 'Chla'
   description   ' achlc*A'
end-output
output 'Etot'
   description   ' E0 + Ealg*Chla + Ess*SS + Edet*DET + Eads*ads'
end-output
output 'Secchi'
   description   ' 1/((1/Sd0) + Sdalg*Chla + Sdss*SS + Sddet*DET + S'
end-output

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:settingsWpf="clr-namespace:DeltaShell.Plugins.DelftModels.HydroModel.Gui.Forms.SettingsWpf">
    <GridLength x:Key ="LabelLength">200</GridLength>
    <GridLength x:Key ="ControlLength">*</GridLength>
    <GridLength x:Key ="UnitLength">47</GridLength>

    <Style x:Key="LabelTextBlockStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
    </Style>

    <Style x:Key="ControlStyle" TargetType="Control">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="4,2,4,2"/>
    </Style>

    <Style x:Key="GridStyle" TargetType="Grid">
        <Setter Property="Margin" Value="2"/>
    </Style>
</ResourceDictionary>
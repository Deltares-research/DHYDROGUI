<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                  auto-import="false"
                  namespace="DeltaShell.Plugins.DelftModels.HydroModel.ValueConverters"
                  assembly="DeltaShell.Plugins.DelftModels.HydroModel">

  <subclass name="HydroRegionFeatureCoverageFromNetworkCoverageValueConverter" lazy="false" 
            extends="DelftTools.Shell.Core.Workflow.DataItems.IValueConverter, DelftTools.Shell.Core" 
            discriminator-value="hydro_region_feature_coverage_from_network_coverage_converter" >

    <many-to-one name="ConvertedValue"
                 cascade="save-update"
                 class="NetTopologySuite.Extensions.Coverages.NetworkCoverage, NetTopologySuite.Extensions"
                 column="network_coverage_id" />

    <many-to-one name="HydroRegion"
                cascade="save-update"
                class ="DelftTools.Hydro.HydroRegion, DelftTools.Hydro"/>

  </subclass>
</hibernate-mapping>
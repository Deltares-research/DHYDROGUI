<?xml version="1.0"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>
  <appSettings>
    <add key="pluginsDirectory" value="../plugins" />
    <add key="language" value="en-US" />
  </appSettings>
  <log4net>
    <appender name="consoleAppender" type="log4net.Appender.ConsoleAppender">
      <layout type="log4net.Layout.PatternLayout">
        <!--        <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" /> -->
        <conversionPattern value="%message%newline"/>
      </layout>
    </appender>

    <appender name="fileAppender" type="log4net.Appender.FileAppender">
      <file value="DeltaShell.log"/>
      <appendToFile value="false"/>
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %logger.%M - %message%newline"/>
      </layout>
    </appender>
    <root>
      <level value="INFO"/>
      <appender-ref ref="consoleAppender"/>
    </root>
    <logger name="DelftTools.Utils.Aop" additivity="false">
      <level value="ERROR"/>
      <appender-ref ref="consoleAppender"/>
    </logger>
    <logger name="DeltaShell.Plugins.Data.NHibernate" additivity="false">
      <level value="ERROR"/>
      <appender-ref ref="consoleAppender"/>
    </logger>
    <!-- NHIbernate logger is needed :( otherwise we crash or veeery slow. Log into void-->
    <logger name="NHibernate" additivity="false">
      <level value="ERROR"/>
    </logger>
  </log4net>
  <startup>
    <supportedRuntime version="v2.0.50727"/>
  </startup>
</configuration>

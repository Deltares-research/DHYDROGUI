<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DelftTools.Hydro.Link1d2d"
                   assembly="DelftTools.Hydro">

  <subclass name="Link1D2DCoverage" extends="DelftTools.Functions.Function, DelftTools.Functions" lazy="false"  discriminator-value="link1d2d_coverage">
    <meta attribute="anyType">IValueConverter.OriginalValue</meta>

    <many-to-one name="Grid" class="NetTopologySuite.Extensions.Grids.UnstructuredGrid, NetTopologySuite.Extensions" cascade="save-update"/>
    <many-to-one name="Discretization" class="GeoAPI.Extensions.Coverages.IDiscretization, GeoAPI.Extensions" cascade="save-update"/>
    <list name="Links" cascade="save-update" table="links_1d2d" batch-size="200" collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[DelftTools.Hydro.Link1d2d, DelftTools.Hydro]], DeltaShell.Plugins.Data.NHibernate" >
      <key column="function_id"/>
      <index column="link1d2d_list_index" />
      <many-to-many class="DelftTools.Hydro.Link1d2d, DelftTools.Hydro" column="variable_id" />
    </list>

    <!-- 
      mapping NHStore required to have proper deserialized Arguments/Components. 
      Letting mapping inherit from Function was causing deserialization problems for functions 
      being serialized with discriminator-value equal to "gis-coverage" (ICoverage mapping).
    -->
    <many-to-one name="NHStore" cascade="all-delete-orphan" column="function_store_id" />

    
  </subclass>
</hibernate-mapping>

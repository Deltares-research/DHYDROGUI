<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2">
  
  <!-- NHibernate mapping for LateralSourceGridCell type -->
  <subclass name=" DelftTools.Hydro.LateralSourceGridCell, DelftTools.Hydro" discriminator-value="lateral_source_cell"
            extends="GeoAPI.Extensions.Networks.IBranchFeature, GeoAPI.Extensions">
    <many-to-one name="LateralSource" cascade="save-update" class="DelftTools.Hydro.LateralSource, DelftTools.Hydro" column="lateral_source_id"/>
    <!--Map Branch separately as LateralSourceGridCell objects are not added to Brach.BranchFeatures in order to prevent them from appearing in network contents-->
    <many-to-one name="Branch" class="GeoAPI.Extensions.Networks.IBranch" column="lateral_source_cell_branch_id" />
  </subclass>
  
  <!-- Maps and associates LateralSourceGridCell to the values of a variable -->
  <subclass name="DelftTools.Functions.Generic.Variable`1[[DelftTools.Hydro.LateralSourceGridCell, DelftTools.Hydro]], DelftTools.Functions"
            lazy="false"
            discriminator-value="lateral_source_cell"
            extends="DelftTools.Functions.IVariable,DelftTools.Functions"/>

  <!-- Maps and associates LateralSourceGridCell to the values of a multi dimensional array -->
  <subclass name="DelftTools.Functions.Generic.MultiDimensionalArray`1[[DelftTools.Hydro.LateralSourceGridCell, DelftTools.Hydro]], DelftTools.Functions"
            lazy="false"
            discriminator-value="lateral_source_cell"
            extends="DelftTools.Functions.MultiDimensionalArray, DelftTools.Functions">

    <list name="Values"
          batch-size="25"
          cascade="save-update"
          table="md_array_lateral_source_cells">
      <key column="lateral_source_cell_id"/>
      <index column="md_array_lateral_source_cells_list_index"/>
      <many-to-many class=" DelftTools.Hydro.LateralSourceGridCell, DelftTools.Hydro"/>
    </list>

  </subclass>
</hibernate-mapping>

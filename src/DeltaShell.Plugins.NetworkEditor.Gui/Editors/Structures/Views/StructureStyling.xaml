<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GridLength x:Key="BoxColumn">7*</GridLength>
    <GridLength x:Key="IsTimeSeriesColumn">*</GridLength>
    <GridLength x:Key="LeftPane">3*</GridLength>
    <GridLength x:Key="RightPane">2*</GridLength>

    <Style x:Key="StructuresView" TargetType="StackPanel">
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style x:Key="StructuresControl" TargetType="Grid">
        <Setter Property="Margin" Value="10 0 10 0" />
    </Style>
</ResourceDictionary>
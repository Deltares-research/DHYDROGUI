<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">

  <joined-subclass name="DeltaShell.Plugins.DelftModels.RainfallRunoff.RainfallRunoffModel" lazy="false"
                   extends="DelftTools.Shell.Core.Workflow.IModel, DelftTools.Shell.Core" table="rr_0d_model">
    <key column="project_item_id" />
    
    <property name="CapSim"/>
    <property name="CapSimInitOption"/>
    <property name="CapSimCropAreaOption"/>

    <property name="UseSaveStateTimeRange" />
    <property name="SaveStateStartTime" />
    <property name="SaveStateStopTime" />
    <property name="SaveStateTimeStep" />
      
    <many-to-one class="RainfallRunoffOutputSettingData" access="property" name="OutputSettings"
                 cascade="all-delete-orphan" />

    <list name="ModelData" batch-size="4" cascade="all-delete-orphan" collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData, DeltaShell.Plugins.DelftModels.RainfallRunoff]], DeltaShell.Plugins.Data.NHibernate"  >
      <key column="parent_catchmentdata_id"/>
      <index column="index_in_parent" />
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData, DeltaShell.Plugins.DelftModels.RainfallRunoff"  />
    </list>
    
    <list name="BoundaryData" batch-size="4" cascade="all-delete-orphan" collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.RunoffBoundaryData, DeltaShell.Plugins.DelftModels.RainfallRunoff]], DeltaShell.Plugins.Data.NHibernate"  >
      <key column="parent_boundarydata_id"/>
      <index column="index_in_parent" />
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.RunoffBoundaryData, DeltaShell.Plugins.DelftModels.RainfallRunoff"  />
    </list>

    <list name="MeteoStations" cascade="all-delete-orphan" collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[System.String]], DeltaShell.Plugins.Data.NHibernate">
      <key column="parent_meteostation_id"/>
      <index column="index_in_parent"/>
      <element type="System.String"/>
    </list>

    <list name="TemperatureStations" cascade="all-delete-orphan" collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[System.String]], DeltaShell.Plugins.Data.NHibernate">
      <key column="parent_tempstation_id"/>
      <index column="index_in_parent"/>
      <element type="System.String"/>
    </list>
    
    <list name="NwrwDryWeatherFlowDefinitions" cascade="all-delete-orphan">
      <key column="parent_dryweatherflowdef_id"/>
      <index column="index_in_parent"/>
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwDryWeatherFlowDefinition, DeltaShell.Plugins.DelftModels.RainfallRunoff"  />
    </list>

    <list name="NwrwDischargeData" cascade="all-delete-orphan">
      <key column="parent_dischargedata_id"/>
      <index column="index_in_parent"/>
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwDischargeData, DeltaShell.Plugins.DelftModels.RainfallRunoff"  />
    </list>
    <map cascade="all" name="NwrwGlobalDataDict" table="nwrw_globaldata_dictionary" mutable="true">
      <key>
        <column name="`project_item_id`" />
      </key>
      <index type="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwSurfaceType, DeltaShell.Plugins.DelftModels.RainfallRunoff">
        <column name="`NwrwSurfaceType`" />
      </index>
      <many-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwGlobalData, DeltaShell.Plugins.DelftModels.RainfallRunoff">
        <column name="`NwrwGlobalDataID`" />
      </many-to-many>
    </map>

    <!--
    <map name="NwrwGlobalDataDict" access="property" table="nwrw_globaldata_dictionary" cascade="save-update">
      <key column="nwrw_global_data_dict_id"/>
      <index column="NwrwSurfaceType" type="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwSurfaceType, DeltaShell.Plugins.DelftModels.RainfallRunoff" />
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwGlobalData, DeltaShell.Plugins.DelftModels.RainfallRunoff"/>
    </map>-->
    
  </joined-subclass>

</hibernate-mapping>
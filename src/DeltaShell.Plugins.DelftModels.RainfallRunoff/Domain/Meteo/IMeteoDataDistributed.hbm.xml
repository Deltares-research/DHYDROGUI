<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Meteo"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">
  <class name="IMeteoDataDistributed" table="rr_meteodata_dist">
    <id name="Id" type="Int64" unsaved-value="0" access="property" column="rr_meteodata_id">
      <generator class="increment"/>
    </id>
    <joined-subclass
    name="MeteoDataDistributedGlobal"
    extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Meteo.IMeteoDataDistributed,DeltaShell.Plugins.DelftModels.RainfallRunoff"
    table="meteo_global"
    lazy="false">
      <key column="rr_meteodata_id"/>
      <many-to-one
        name="Data"
        cascade="all-delete-orphan"
        class="DelftTools.Functions.TimeSeries, DelftTools.Functions"
        column="timeseries_id" />
    </joined-subclass>
    <joined-subclass
    name="MeteoDataDistributedPerFeature"
    extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Meteo.IMeteoDataDistributed,DeltaShell.Plugins.DelftModels.RainfallRunoff"
    table="meteo_features"
    lazy="false">
      <key column="rr_meteodata_id"/>
      <many-to-one
        name="Data"
        cascade="all-delete-orphan"
        class="NetTopologySuite.Extensions.Coverages.FeatureCoverage, NetTopologySuite.Extensions"
        column="feature_coverage_id" />
    </joined-subclass>
    <joined-subclass
    name="MeteoDataDistributedPerStation"
    extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Meteo.IMeteoDataDistributed,DeltaShell.Plugins.DelftModels.RainfallRunoff"
    table="meteo_stations"
    lazy="false">
      <key column="rr_meteodata_id"/>
      <many-to-one
        name="Data"
        cascade="all-delete-orphan"
        class="DelftTools.Functions.Function, DelftTools.Functions"
        column="meteostations_id" />
    </joined-subclass>
  </class>
</hibernate-mapping>
<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">
  <class name="CatchmentModelData" table="rr_modeldata" lazy="false">
    <id name="Id" column="id" type="Int64" unsaved-value="0" access="property">
      <generator class="increment" />
    </id>
    <property name="CalculationArea"/>
    <property name="MeteoStationName"/>
    <property name="TemperatureStationName"/>
    <property name="AreaAdjustmentFactor"/>
    <list name="SubCatchmentModelData"
          cascade="all-delete-orphan" 
          collection-type="DeltaShell.Plugins.Data.NHibernate.Collections.Generic.PersistentEventedListType`1[[DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData, DeltaShell.Plugins.DelftModels.RainfallRunoff]], DeltaShell.Plugins.Data.NHibernate"  >
      <key column="parent_subcatchmentdata_id"/>
      <index column="index_in_parent" />
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData, DeltaShell.Plugins.DelftModels.RainfallRunoff"  />
    </list>
    <many-to-one 
      name="Catchment" 
      cascade="save-update" 
      class="DelftTools.Hydro.Catchment, DelftTools.Hydro" 
      column="catchment_id" />
  </class>

</hibernate-mapping>
<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">
  <joined-subclass extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData" 
                   name="UnpavedData" table="rr_unpaved" lazy="false">
    <key column="Id"/>
    
    <property name="UseDifferentAreaForGroundWaterCalculations" />
    <property name="TotalAreaForGroundWaterCalculations" />
    <property name="SurfaceLevel" />
    <property name="SoilType" />
    <property name="SoilTypeCapsim" />
    <property name="GroundWaterLayerThickness" />
    <property name="MaximumAllowedGroundWaterLevel" />
    <property name="InitialGroundWaterLevelSource" />
    <property name="InitialGroundWaterLevelConstant" />
    <property name="MaximumLandStorage" />
    <property name="InitialLandStorage" />
    <property name="LandStorageUnit" />
    <property name="InfiltrationCapacity" />
    <property name="InfiltrationCapacityUnit" />
    <property name="SeepageSource" />
    <property name="SeepageConstant" />
    <property name="SeepageH0HydraulicResistance" />
      
    <!--Area Per Crop Dictionary, mapped by (binary) serialization-->
    <property name="AreaPerCrop" />
    
    <many-to-one name="BoundaryData" cascade="all-delete-orphan"
                 class="DeltaShell.Plugins.DelftModels.RainfallRunoff.RainfallRunoffBoundaryData"/>
    
    <!--Drainage Formula-->
    <many-to-one name="DrainageFormula" cascade="all-delete-orphan"
                 class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Unpaved.IDrainageFormula"
                 column="DrainageFormulaId" />

    <many-to-one name="InitialGroundWaterLevelSeries" cascade="all-delete-orphan"
                 class="DelftTools.Functions.TimeSeries, DelftTools.Functions" column="InitialGroundWaterLevelSeriesId" />

    <many-to-one name="SeepageSeries" cascade="all-delete-orphan" class="DelftTools.Functions.TimeSeries, DelftTools.Functions"
                 column="SeepageSeriesId" />

    <many-to-one name="SeepageH0Series" cascade="all-delete-orphan" class="DelftTools.Functions.TimeSeries, DelftTools.Functions"
                 column="SeepageH0SeriesId" />

  </joined-subclass>
</hibernate-mapping>
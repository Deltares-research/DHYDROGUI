<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">
  <joined-subclass extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData"
                   name="NwrwData" table="rr_nwrw" lazy="false">

    <key column="Id"/>

    <property name="NodeOrBranchId" />
    <property name="DischargeType" type="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.DischargeType, DeltaShell.Plugins.DelftModels.RainfallRunoff"/>
    <property name="DryWeatherFlowIdInhabitant" />
    <property name="DryWeatherFlowIdCompany" />
    <map name="SurfaceLevelDict" access="property" table="nwrw_surface_level_dictionary" cascade="save-update">
      <key column="nwrw_data_dict_id"/>
      <index column="NwrwSurfaceType" type="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwSurfaceType, DeltaShell.Plugins.DelftModels.RainfallRunoff" />
      <element column="Value" type="System.Double" />
    </map>
    <property name="MeteoStationId" />
    <property name="NumberOfPeople" />

    <property name="NumberOfSpecialAreas" />
    <list name="SpecialAreas" access="property" lazy="true" cascade="all">
      <key column="nwrw_special_area_key"/>
      <index column="nwrw_special_area_index" />
      <one-to-many class="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts.Nwrw.NwrwSpecialArea, DeltaShell.Plugins.DelftModels.RainfallRunoff" />
    </list>






  </joined-subclass>
</hibernate-mapping>

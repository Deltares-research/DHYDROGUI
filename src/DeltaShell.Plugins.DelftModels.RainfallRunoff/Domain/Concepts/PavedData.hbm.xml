<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   namespace="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.Concepts"
                   assembly="DeltaShell.Plugins.DelftModels.RainfallRunoff">
  <joined-subclass extends="DeltaShell.Plugins.DelftModels.RainfallRunoff.Domain.CatchmentModelData" 
                   name="PavedData" table="rr_paved" lazy="false">
    <key column="Id"/>
    
    <property name="SurfaceLevel" />
    <property name="SpillingDefinition" />
    <property name="RunoffCoefficient" />
    <property name="SewerType" />
    <property name="IsSewerPumpCapacityFixed" />
    <property name="CapacityMixedAndOrRainfall" />
    <property name="CapacityDryWeatherFlow" />
    <property name="SewerPumpCapacityUnit" />
    <property name="MaximumStreetStorage" />
    <property name="InitialStreetStorage" />
    <property name="MaximumSewerMixedAndOrRainfallStorage" />
    <property name="InitialSewerMixedAndOrRainfallStorage" />
    <property name="MaximumSewerDryWeatherFlowStorage" />
    <property name="InitialSewerDryWeatherFlowStorage" />
    <property name="StorageUnit" />
    <property name="NumberOfInhabitants" />
    <property name="DryWeatherFlowOptions" />
    <property name="WaterUse" />
    <property name="WaterUseUnit" />
    <property name="MixedAndOrRainfallSewerPumpDischarge" />
    <property name="DryWeatherFlowSewerPumpDischarge" />

    <!-- TimeSeries -->
    <many-to-one name="MixedSewerPumpVariableCapacitySeries" cascade="all"
                 class="DelftTools.Functions.TimeSeries, DelftTools.Functions" column="MixedSewerPumpVariableCapacitySeriesId" />
      
    <!-- TimeSeries -->
    <many-to-one name="DwfSewerPumpVariableCapacitySeries" cascade="all"
                 class="DelftTools.Functions.TimeSeries, DelftTools.Functions" column="DwfSewerPumpVariableCapacitySeriesId" />
      
    <!-- Function -->
    <many-to-one name="VariableWaterUseFunction" cascade="all"
                 class="DelftTools.Functions.Function, DelftTools.Functions" column="VariableWaterUseFunctionId" />

  </joined-subclass>
</hibernate-mapping>
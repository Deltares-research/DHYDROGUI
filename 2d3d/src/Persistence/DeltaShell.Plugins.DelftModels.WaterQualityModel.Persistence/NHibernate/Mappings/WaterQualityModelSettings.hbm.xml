<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   auto-import="false"
                   namespace="DeltaShell.Plugins.DelftModels.WaterQualityModel.DataObjects.Model"
                   assembly="DeltaShell.Plugins.DelftModels.WaterQualityModel">

  <class name="WaterQualityModelSettings"
         lazy="false"
         table="wq_model_settings">

    <id name="Id" column="wq_model_settings_id" type="Int64">
      <generator class="increment" />
    </id>

    <property name="HisStartTime" column="his_start_time" />
    <property name="HisStopTime" column="his_stop_time" />
    <property name="HisTimeStep" column="his_time_step" />
    <property name="MapStartTime" column="map_start_time" />
    <property name="MapStopTime" column="map_stop_time" />
    <property name="MapTimeStep" column="map_time_step" />
    <property name="BalanceStartTime" column="balance_start_time" />
    <property name="BalanceStopTime" column="balance_stop_time" />
    <property name="BalanceTimeStep" column="balance_time_step" />
    <property name="NumericalScheme" column="numerical_scheme" />
    <property name="NoDispersionIfFlowIsZero" column="no_dispersion_flow_zero" />
    <property name="NoDispersionOverOpenBoundaries" column="no_dispersion_open_boundaries" />
    <property name="UseFirstOrder" column="use_first_order" />
    <property name="UseForesterFilter" column="use_forester_filter" />
    <property name="UseAnticreepFilter" column="use_anticreep_filter" />
    <property name="Balance" column="balance" />
    <property name="LumpProcesses" column="lump_processes" />
    <property name="LumpTransport" column="lump_transport" />
    <property name="LumpLoads" column="lump_loads" />
    <property name="SuppressSpace" column="suppress_space" />
    <property name="SuppressTime" column="suppress_time" />
    <property name="BalanceUnit" column="balance_unit" />
    <property name="ProcessesActive" column="processes_active" />
    <property name="MonitoringOutputLevel" column="monitoring_output_level" />
    <property name="CorrectForEvaporation" column="correct_for_evaporation" />
    <property name="NoBalanceMonitoringPoints" column="no_balance_monitoring_points" />
    <property name="NoBalanceMonitoringAreas" column="no_balance_monitoring_areas" />
    <property name="NoBalanceMonitoringModelWide" column="no_balance_model_wide" />

    <property name="ClosureErrorCorrection" />
    <property name="NrOfThreads" />
    <property name="DryCellThreshold" />
    <property name="IterationMaximum" />
    <property name="Tolerance" />
    <property name="WriteIterationReport" />
    <property name="OutputDirectory" />

  </class>

</hibernate-mapping>
<?xml version="1.0" encoding="utf-8"?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   auto-import="false"
                   namespace="DeltaShell.Plugins.DelftModels.WaterQualityModel.DataObjects.SubstanceProcessLibrary"
                   assembly="DeltaShell.Plugins.DelftModels.WaterQualityModel">

  <class name="WaterQualityParameter"
         lazy="false"
         table="wq_parameter">

    <id name="Id" column="parameter_id" type="Int64">
      <generator class="increment" />
    </id>

    <property name="Name" column="name" />
    <property name="Description" column="description" />
    <property name="Unit" column="unit" />
    <property name="DefaultValue" column="default_value" />

  </class>

</hibernate-mapping>
    </TestRunner>
  </NUnit>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <probing privatePath="DeltaShell;plugins;plugins\DeltaShell.Plugins.Scripting;plugins\DeltaShell.Plugins.Data.NHibernate" />
      <dependentAssembly>
        <assemblyIdentity name="nunit.framework" publicKeyToken="2638cd05610744eb" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-3.13.3.0" newVersion="3.13.3.0" />
      </dependentAssembly>
    <probing privatePath="DeltaShell;plugins;plugins\DeltaShell.Plugins.Data.NHibernate" /></assemblyBinding>
  </runtime>
</configuration>

[MorphologyFileInformation]
   FileCreatedBy    = Richard Measures         
   FileCreationDate = Wed Feb 20 2013, 17:08:20         
   FileVersion      = 02.00                        
[Morphology]
   IopKCW           = 1                             Flag for determining Rc and Rw         
   MorFac           =  1.0000000e+000      [-]      Morphological scale factor
   MorStt           =  1.0000000e+001      [min]    Spin-up interval from TStart till start of morphological changes
   Thresh           =  2.5000000e-002      [m]      Threshold sediment thickness for transport and erosion reduction
   MorUpd           = true                          Update bathymetry during FLOW simulation   
   CmpUpd           = true                          Update bed composition during flow simulation
   EqmBc            = true                          Equilibrium sand concentration profile at inflow boundaries
   DensIn           = false                         Include effect of sediment concentration on fluid density
   AksFac           =  1.0000000e+000      [-]      van Rijn's reference height = AKSFAC * KS
   AlfaBs           =  1.0000000e+000      [-]      Streamwise bed gradient factor for bed load transport (default = 1.0)
   AlfaBn           =  1.5000000e+000      [-]      Transverse bed gradient factor for bed load transport (default = 1.5)
   Sus              =  1.0000000e+000      [-]      Multiplication factor for suspended sediment reference concentration
   Bed              =  1.0000000e+000      [-]      Multiplication factor for bed-load transport vector magnitude
   SusW             =  1.0000000e+000      [-]      Wave-related suspended sed. transport factor
   BedW             =  1.0000000e+000      [-]      Wave-related bed-load sed. transport factor
   SedThr           =  1.0000000e-002      [m]      Minimum water depth for sediment computations
   ThetSD           =  0.0000000e+000      [-]      Factor for erosion of adjacent dry cells
   HMaxTH           =  0.0000000e+000      [m]      Max depth for variable THETSD. Set < SEDTHR to use global value only
   IHidExp          = 1                    [-]      Hiding and exposure forumlation number
   ISlope           = 1                    [-]      bed slope formulation (options 1-4 see manual table B.6)
   FWFac            =  1.0000000e+000      [-]      Vertical mixing distribution according to van Rijn (overrules k-epsilon model)
[Numerics]
   UpwindBedload    = true                 [-]      use upwind bed load (true, default) or central bed load (false)
[Output]
   ShearVeloc       = true                 [-]      Output shear velocity u*
   Dg               = true                 [-]      Output geometric mean sediment diameter
   SandFrac         = true                 [-]      Output sand fraction (excluding mud) in top layer (non-standard option)
   Dgsd             = true                 [-]      Output geometric standard deviation of grain size distribution
   Percentiles      = #10 50 90#           [%]      Percentiles of characteristic sediment diameter to be written to the map file
[Underlayer]
   IUnderLyr        = 1                    [-]      Stratigraphy schematisation model (1 = single layer, 2 = multiple layers)
   UpdBaseLyr       = 1                    [-]      Update option for composition and thickness of base layer (options 1-4 see manual table B.6)
   concentration-unit 'g/m'
   waste-load-unit    '-'
end-substance
substance 'SSW' active
   description        'ZWEVENDE STOF WATERKOLOM'
   concentration-unit 'g/m'
   waste-load-unit    '-'
end-substance
substance 'DOCW' active
   description        'OPGELOST ORGANISCH C WATERKOLOM'
   concentration-unit 'g/m'
   waste-load-unit    '-'
end-substance
substance 'AOCW' active
   description        'ALGEN KOOLSTOF'
   concentration-unit 'g/M'
   waste-load-unit    '-'

   description        'OPGELOST ORGANISCH C TOPLAAG'
   concentration-unit 'g/m'
   waste-load-unit    '-'
end-substance
substance 'POCB' inactive
   description        'PARTICULAIR ORGANISCH C TOPLAAG'
   concentration-unit 'g/m'

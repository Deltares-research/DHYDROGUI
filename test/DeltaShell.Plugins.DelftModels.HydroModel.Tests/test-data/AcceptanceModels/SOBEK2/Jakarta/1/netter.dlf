DLF1.0
[Rainfall Runoff Module: Simulation Results]
FILE "@balansdt.his"     LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Balances per Timestep
FILE "@3blinks.his"      LAYER " " TYPE branch VAR 1 HISLOC 2 LINKSEP ""    = Flows on Links
FILE "@bndflodt.his"     LAYER " " TYPE node VAR 1 HISLOC 2                 = Boundary Nodes
FILE "@bndfltot.his"     LAYER " " TYPE node VAR 1 HISLOC 2                 = Daily Totals towards Boundary
FILE "@sacrmnto.his"    LAYER " " TYPE node VAR 1 HISLOC 2                 = Sacramento Nodes
[Rainfall Runoff Module: Dimensions]
FILE "@3bareas.his"      LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Node Areas
[Flow Module: Levels and Flows]
FILE "@calcpnt.his"      LAYER " " TYPE node VAR 1 HISLOC 2                 = Results at Nodes
FILE "@reachseg.his"     LAYER " " TYPE reachgridvirtual VAR 1 HISLOC 2     = Results at Reach Segments
FILE "@qlat.his"         LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Lateral Flows
FILE "@struc.his"        LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Results at Structures
FILE "@measstat.his"     LAYER " " TYPE network VAR 1 HISLOC 2              = Results at Measurement Stations
FILE "@flowanal.his"    LAYER " " TYPE reachgridvirtual VAR 6 HISLOC 2     = Simulation Info at the Reach Segments
[Flow Module: Dimensions]
FILE "@calcdim.his"      LAYER " " TYPE node VAR 1 HISLOC 2                 = Nodes
FILE "@reachdim.his"     LAYER " " TYPE reachgridvirtual VAR 1 HISLOC 2     = Reach Segments
FILE "@strucdim.his"     LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Structures
[Overland Flow Module]
FILE "@fls_h.inc"        LAYER " " TYPE d2grid VAR 1 HISLOC 2               = Depths (incremental)
FILE "@???d????.MAP"     LAYER " " TYPE d2grid VAR 1 HLF "@FLS_GIS.HLF"     = Depths (MAP)
FILE "@???r????.MAP"     LAYER " " TYPE d2grid VAR 1 HLF "@FLS_GIS.HLF"     = Rate Depth Change (MAP)
FILE "@???h????.MAP"     LAYER " " TYPE d2grid VAR 1 HLF "@FLS_GIS.HLF"     = Levels (MAP)
FILE "@???c????.MAP"     LAYER " " TYPE d2grid VAR 1 HLF "@FLS_GIS.HLF"     = Velocities (MAP)
FILE "@???MAXD?.ASC"     LAYER " " TYPE d2grid                              = Maximum Depths (GIS)
FILE "@???MAXH?.ASC"    LAYER " " TYPE d2grid                              = Maximum Levels (GIS)
FILE "@???MAXC?.ASC"    LAYER " " TYPE d2grid                              = Maximum Velocities (GIS)
FILE "@???NEGDP.ASC"    LAYER " " TYPE d2grid                              = 2D Flow Analysis Negative Depth (GIS)
FILE "@???TSU.ASC"      LAYER " " TYPE d2grid                              = 2D Flow Analysis Timestep U-Direction  (GIS)
FILE "@???TSV.ASC"      LAYER " " TYPE d2grid                              = 2D Flow Analysis Timestep V-Direction (GIS)

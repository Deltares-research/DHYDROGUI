<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>DHYDRO.Common</id>
    <title>DHYDRO.Common</title>
    <description>A shared D-HYDRO Suite code library.</description>
    <version>1.2.0</version>
    <authors>Deltares</authors>
    <copyright>Deltares 2023</copyright>
    <dependencies>
      <group targetFramework=".NETFramework4.8" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\bin\$configuration$\*" target="lib\net48" />
    <file src="build\**\*" target="build"/>
  </files>
</package>
<Project Sdk="Microsoft.NET.Sdk">

    <!--Source Link-->
    <PropertyGroup>
        <!-- Publish the repository URL in the built .nupkg (in the NuSpec <Repository> element) -->
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <!-- Embed source files that are not tracked by the source control manager in the PDB -->
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <!-- Recommended: Embed symbols containing Source Link in the main file (exe/dll) -->
        <DebugType>embedded</DebugType>
    </PropertyGroup>

    <PropertyGroup Condition="'$(BUILD_SERVER)' == 'true'">
        <!--Set to true with a build server build to normalize stored file paths. Should be false during local dev or the debugger won’t be able to find the local source files.-->
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="1.0.0" PrivateAssets="All"/>
    </ItemGroup>

    <PropertyGroup>
        <BuildNumber>0</BuildNumber>
        <GitHash>DEV</GitHash>
    </PropertyGroup>

    <PropertyGroup>
        <OutputPath>$(SolutionDir)\bin\$(Configuration)\src\</OutputPath>
        <CheckForOverflowUnderflow>True</CheckForOverflowUnderflow>
        <CodeAnalysisRuleSet>AllRules.ruleset</CodeAnalysisRuleSet>
        <NoWarn>1591</NoWarn>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <TargetFramework>net48</TargetFramework>
        <LangVersion>7.3</LangVersion>
        <Company>Deltares</Company>
        <Copyright>Copyright © Deltares 2022</Copyright>
        <AssemblyTitle>$(AssemblyName)</AssemblyTitle>
        <Product>$(AssemblyName)</Product>
        <DHYDROFileVersion>1.0.0</DHYDROFileVersion>
        <Version>$(DHYDROFileVersion).$(BuildNumber)</Version>
        <FileVersion>$(Version)</FileVersion>
        <InformationalVersion>$(Version).$(GitHash)</InformationalVersion>
        <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
        <DebugType>full</DebugType>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
        <DebugType>pdbonly</DebugType>
        <DebugSymbols>True</DebugSymbols>
    </PropertyGroup>

    <ItemGroup>
        <Resource Include="Resources\**"/>
    </ItemGroup>

    <!--Ensure resources are generated correctly.-->
    <ItemGroup Condition="Exists('Properties\Resources.resx')">
        <Compile Update="Properties\Resources.Designer.cs">
            <DesignTime>True</DesignTime>
            <AutoGen>True</AutoGen>
            <DependentUpon>Resources.resx</DependentUpon>
        </Compile>
    </ItemGroup>
    <ItemGroup Condition="Exists('Properties\Resources.resx')">
        <EmbeddedResource Update="Properties\Resources.resx">
            <Generator>ResXFileCodeGenerator</Generator>
            <LastGenOutput>Resources.Designer.cs</LastGenOutput>
        </EmbeddedResource>
    </ItemGroup>
</Project>    
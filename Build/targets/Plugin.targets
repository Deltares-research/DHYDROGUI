<Project>
  <Import Project="Source.targets" />
  <ItemGroup>
    <AssemblyAttribute Include="Mono.Addins.Addin">
      <_Parameter1>$(AssemblyName).Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="Mono.Addins.AddinDependency">
      <_Parameter1>DeltaShellApplication</_Parameter1>
      <_Parameter2>1.0</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>
  
  <PropertyGroup>
    <OutputPath>$(SolutionDir)bin\$(Configuration)\plugins\$(AssemblyName)</OutputPath>
  </PropertyGroup>
</Project>
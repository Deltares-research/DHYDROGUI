DLF1.0
[Flow Module: Results]
FILE "@calcpnt.his"      LAYER " " TYPE node VAR 1 HISLOC 2                 = Results at Nodes
FILE "@reachseg.his"     LAYER " " TYPE reachgridvirtual VAR 1 HISLOC 2     = Results at Reach Segments
FILE "@rsegsub.his"      LAYER " " TYPE reachgridvirtual VAR 1 HISLOC 2     = Results at Sub Sections
FILE "@reachvol.his"     LAYER " " TYPE branch VAR 1 HISLOC 2               = Info at Reach Segments
FILE "@reachflw.his"     LAYER " " TYPE branch VAR 1 HISLOC 2               = Flow Balance of Reach Segments
FILE "@qlat.his"         LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Lateral Flows
FILE "@qwb.his"         LAYER " " TYPE node VAR 1 HISLOC 2                 = Water Balance
FILE "@flowanal.his"    LAYER " " TYPE reachgridvirtual VAR 6 HISLOC 2     = Simulation Info at the Reach Segments
[Flow Module: Dimensions]
FILE "@calcdim.his"      LAYER " " TYPE node VAR 1 HISLOC 2                 = Nodes
FILE "@reachdim.his"     LAYER " " TYPE reachgridvirtual VAR 1 HISLOC 2     = Reach Segments
[Water Quality Module]
FILE "@wqbou20.his"      LAYER " " TYPE delwaq VAR 1 HISLOC 2               = Balance of Water Quantity
FILE "@delwaq.his"       LAYER " " TYPE delwaq VAR 1 HISLOC 2               = History Results of Water Quality
FILE "@delwaq.map"       LAYER " " TYPE delwaq VAR 1 HISLOC 2               = Map Results of Water Quality

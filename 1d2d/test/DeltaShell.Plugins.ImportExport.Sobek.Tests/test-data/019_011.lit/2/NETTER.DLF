DLF1.0
[Rainfall Runoff Module: Simulation Results]
FILE "@balansdt.his"     LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Balances per Timestep
FILE "@3blinks.his"      LAYER " " TYPE branch VAR 1 HISLOC 2 LINKSEP ""    = Flows on Links
FILE "@upflowdt.his"     LAYER " " TYPE node VAR 1 HISLOC 2                 = Unpaved Nodes
FILE "@bndflodt.his"     LAYER " " TYPE node VAR 1 HISLOC 2                 = Boundary Nodes
FILE "@bndfltot.his"     LAYER " " TYPE node VAR 1 HISLOC 2                 = Daily Totals towards Boundary
[Rainfall Runoff Module: Dimensions]
FILE "@3bareas.his"      LAYER " " TYPE network VAR 1 HISLOC 2 LINKSEP "l_" = Node Areas

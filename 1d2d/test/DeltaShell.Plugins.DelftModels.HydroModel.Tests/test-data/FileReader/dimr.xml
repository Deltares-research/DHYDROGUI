    </item>
    <item>
      <sourceName>output_Blok4_Vees_wap_Crest level (s)</sourceName>
      <targetName>weirs/Blok4_Vees_wap/structure_crest_level</targetName>
    </item>
    <logger>
      <workingDir>.</workingDir>
      <outputFile>rtc_to_flow1d.nc</outputFile>
    </logger>
  </coupler>

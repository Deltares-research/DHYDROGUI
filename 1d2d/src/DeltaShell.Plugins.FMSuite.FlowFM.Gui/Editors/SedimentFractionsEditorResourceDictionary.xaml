    <DataTemplate x:Key="SedimentPropertyBoolTemplate">
        <CheckBox Margin="5"
                  VerticalAlignment="Center"
                  Content="{Binding Path=Description}"
                  IsChecked="{Binding Path=Value}" />
    </DataTemplate>
</ResourceDictionary>